---
import { Image } from 'astro:assets';
import ParticleField from './ParticleField.astro';
import profile from '../assets/profile.jpg';
import { localizePath, t, type Lang } from '../lib/i18n';
import { site } from '../lib/site';

const lang: Lang = Astro.currentLocale === 'zh' ? 'zh' : 'en';
const d = t(lang).hero;
const a = t(lang).about;
const L = (p: string) => localizePath(lang, p);
---

<section class="relative overflow-hidden">
  <ParticleField />

  <!-- Contour texture (A2) -->
  <svg
    id="hero-contours"
    class="pointer-events-none absolute -right-24 top-12 w-[640px] max-w-[80vw] opacity-[0.07]"
    viewBox="0 0 600 480" fill="none" aria-hidden="true"
  >
    <path class="contour" d="M300 240 C 360 180, 470 200, 480 270 S 400 400, 300 380 S 130 330, 140 250 S 240 300, 300 240 Z" stroke="currentColor" stroke-width="1.5"/>
    <path class="contour" d="M300 240 C 340 200, 420 215, 430 265 S 370 360, 300 345 S 180 310, 190 255 S 260 280, 300 240 Z" stroke="currentColor" stroke-width="1.2"/>
    <path class="contour" d="M300 245 C 325 220, 375 230, 380 262 S 340 320, 298 310 S 225 290, 232 258 S 275 265, 300 245 Z" stroke="currentColor" stroke-width="1"/>
    <circle cx="300" cy="262" r="4" fill="currentColor"/>
  </svg>

  <div class="relative mx-auto flex max-w-6xl items-center px-6 py-20" style="min-height: calc(100svh - 57px);">
    <div class="grid w-full items-center gap-10 md:grid-cols-[1fr_300px] md:gap-16">
      <!-- Identity + intro -->
      <div>
        <p class="font-mono text-xs sm:text-sm text-ink-muted tracking-wider">
          {d.coords}
        </p>

        <h1 id="hero-name" class="mt-5 font-display text-[clamp(2.75rem,7vw,5rem)] leading-[1.04] tracking-tight">
          {lang === 'zh' ? '李思高' : 'Sigao Li'}
        </h1>

        <p id="hero-tagline" class="mt-4 text-base sm:text-lg text-ink-muted">
          {d.tagline}
        </p>

        <p id="hero-narrative" class="mt-3 max-w-xl font-display text-xl sm:text-2xl" style="color: var(--accent);">
          {d.narrative}
        </p>

        <div id="hero-bio" class="mt-6 max-w-xl space-y-4 text-sm sm:text-base text-ink-muted">
          <p>
            {a.p1} <a class="link-underline" href="https://gisphere.info/" rel="noopener noreferrer" target="_blank">GISphere</a>{a.p1b}
          </p>
          <p>
            {a.p2a} <a class="link-underline" href={L('/photography')}>{a.lensName}</a>{a.p2b}
          </p>
        </div>

        <div id="hero-cta" class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
          <a href={L('/work')}
            class="inline-block rounded-full px-6 py-2.5 text-sm font-medium transition-opacity hover:opacity-85"
            style="background: var(--accent); color: var(--bg);">
            {d.viewWork}
          </a>
          <a href={L('/cv')} class="link-underline text-sm">{a.fullCv}</a>
          <a href={L('/photography')} class="link-underline text-sm">{d.lensLink}</a>
        </div>
      </div>

      <!-- Portrait -->
      <div id="hero-portrait" class="order-first w-44 sm:w-56 md:order-none md:w-full justify-self-center md:justify-self-end">
        <Image
          src={profile}
          alt={a.portraitAlt}
          width={600}
          widths={[240, 300, 600]}
          sizes="(max-width: 768px) 240px, 300px"
          class="rounded-xl border"
          style="border-color: var(--line);"
        />
        <div class="mt-4 flex items-center justify-center gap-5 text-ink-muted">
          <a href={site.socials.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="transition-colors hover:text-accent">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.25.82-.56v-2c-3.34.72-4.04-1.58-4.04-1.58-.55-1.37-1.34-1.74-1.34-1.74-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.21 1.84 1.21 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.24-3.17-.13-.3-.54-1.52.12-3.16 0 0 1.01-.31 3.3 1.21a11.6 11.6 0 0 1 3-.4c1.02 0 2.05.13 3 .4 2.28-1.52 3.29-1.21 3.29-1.21.66 1.64.25 2.86.12 3.16.77.83 1.24 1.88 1.24 3.17 0 4.54-2.81 5.53-5.49 5.83.43.36.81 1.08.81 2.18v3.23c0 .31.21.68.82.56A11.8 11.8 0 0 0 24 12.29C24 5.78 18.63.5 12 .5z"/></svg>
          </a>
          <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="transition-colors hover:text-accent">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
          <a href={`mailto:${site.email}`} aria-label="Email" class="transition-colors hover:text-accent">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="4.5" width="19" height="15" rx="2"/><path d="m3 6.5 9 6 9-6"/></svg>
          </a>
          <a href={site.socials.researchgate} target="_blank" rel="noopener noreferrer" aria-label="ResearchGate" class="transition-colors hover:text-accent">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.97.936-1.213 1.68a3.193 3.193 0 0 0-.112.437 8.365 8.365 0 0 0-.078.53 9 9 0 0 0-.05.727c-.01.282-.013.621-.013 1.016a31.121 31.123 0 0 0 .014 1.017 9 9 0 0 0 .05.727 7.946 7.946 0 0 0 .077.53h-.005a3.334 3.334 0 0 0 .113.438c.245.743.65 1.303 1.214 1.68.565.376 1.256.564 2.075.564.8 0 1.536-.213 2.105-.603.57-.39.94-.916 1.175-1.65.076-.235.135-.558.177-.93a10.9 10.9 0 0 0 .043-1.207v-.82c0-.095-.047-.142-.14-.142h-3.064c-.094 0-.14.047-.14.141v.956c0 .094.046.14.14.14h1.666c.056 0 .084.03.084.086 0 .36 0 .62-.036.865-.038.244-.1.447-.147.606-.108.385-.348.664-.638.876-.29.212-.738.35-1.227.35-.545 0-.901-.15-1.21-.353-.306-.203-.517-.454-.67-.915a3.136 3.136 0 0 1-.147-.762 17.366 17.367 0 0 1-.034-.656c-.01-.26-.014-.572-.014-.939a26.401 26.403 0 0 1 .014-.938 15.821 15.822 0 0 1 .035-.656 3.19 3.19 0 0 1 .148-.76 1.89 1.89 0 0 1 .742-1.01c.344-.244.593-.352 1.137-.352.508 0 .815.096 1.144.303.33.207.528.492.764.925.047.094.111.118.198.07l1.044-.43c.075-.048.09-.115.042-.199a3.549 3.549 0 0 0-.466-.742 3 3 0 0 0-.679-.607 3.313 3.313 0 0 0-.903-.41A4.068 4.068 0 0 0 19.586 0zM8.217 5.836c-1.69 0-3.036.086-4.297.086-1.146 0-2.291 0-3.007-.029v.831l1.088.2c.744.144 1.174.488 1.174 2.264v11.288c0 1.777-.43 2.12-1.174 2.263l-1.088.2v.832c.773-.029 2.12-.086 3.465-.086 1.29 0 2.951.057 3.667.086v-.831l-1.49-.2c-.773-.115-1.174-.487-1.174-2.264v-4.784c.688.057 1.29.057 2.206.057 1.748 3.123 3.41 5.472 4.355 6.56.86 1.032 2.177 1.691 3.839 1.691.487 0 1.003-.086 1.318-.23v-.744c-1.031 0-2.063-.716-2.808-1.518-1.26-1.376-2.95-3.582-4.355-6.074 2.32-.545 4.04-2.722 4.04-4.9 0-3.208-2.492-4.698-5.758-4.698zm-.515 1.29c2.406 0 3.839 1.26 3.839 3.552 0 2.263-1.547 3.782-4.097 3.782-.974 0-1.404-.03-2.063-.086v-7.19c.66-.059 1.547-.059 2.32-.059z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div id="hero-scroll-hint" class="absolute bottom-8 left-6 flex items-center gap-2 text-ink-muted">
      <span class="font-mono text-[11px] tracking-widest">{d.scroll}</span>
      <svg width="12" height="16" viewBox="0 0 12 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <path d="M6 1v12M2 9.5 6 14l4-4.5"/>
      </svg>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin';
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  gsap.registerPlugin(SplitText, DrawSVGPlugin);

  pageScript(() => {
    const name = document.getElementById('hero-name');
    if (!name || prefersReducedMotion()) return;

    const split = SplitText.create(name, { type: 'chars' });
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl.from(split.chars, { y: 90, opacity: 0, duration: 1.1, stagger: 0.04 }, 0.15)
      .from('#hero-portrait', { opacity: 0, scale: 0.96, duration: 0.9, ease: 'power3.out' }, 0.25)
      .from('#hero-tagline', { y: 20, opacity: 0, duration: 0.7, ease: 'power3.out' }, '-=0.7')
      .from('#hero-narrative', { y: 20, opacity: 0, duration: 0.7, ease: 'power3.out' }, '-=0.5')
      .from('#hero-bio', { y: 18, opacity: 0, duration: 0.7, ease: 'power3.out' }, '-=0.45')
      .from('#hero-cta', { y: 16, opacity: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4')
      .from('#hero-contours .contour', { drawSVG: '0%', duration: 1.4, stagger: 0.15, ease: 'power2.inOut' }, 0.4)
      .from('#hero-scroll-hint', { opacity: 0, duration: 0.5 }, '-=0.3');

    return () => {
      tl.kill();
      split.revert();
    };
  });
</script>
