---
// Shared CV page, rendered by /cv and /zh/cv.
import Base from '../../layouts/Base.astro';
import SectionHeading from '../SectionHeading.astro';
import cvEn from '../../data/cv.json';
import cvZh from '../../data/cv.zh.json';
import { t, type Lang } from '../../lib/i18n';

const lang: Lang = Astro.currentLocale === 'zh' ? 'zh' : 'en';
const d = t(lang).cv;
const cv = lang === 'zh' ? cvZh : cvEn;

const fmt = (s: string) => {
  if (s === 'present') return d.present;
  const [y, m] = s.split('-');
  return lang === 'zh'
    ? `${y}年${parseInt(m)}月`
    : new Date(`${s}-01`).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
};

type Entry = {
  title: string;
  org: string;
  location?: string;
  start: string;
  end: string;
  bullets: string[];
};
type Group = { org: string; roles: Entry[]; anchorEnd: number; anchorStart: number };

// Timeline is anchored to the END date: ongoing ("present") sorts newest.
const monthKey = (s: string) => {
  if (s === 'present') return Infinity;
  const [y, m] = s.split('-').map(Number);
  return y * 12 + (m - 1);
};
const byRecentEnd = (a: Entry, b: Entry) =>
  monthKey(b.end) - monthKey(a.end) || monthKey(b.start) - monthKey(a.start);

// Merge consecutive entries at the same org (LinkedIn-style), then order roles
// within each group — and the groups themselves — by end date, most recent first.
function groupEntries(entries: Entry[]): Group[] {
  const groups: Group[] = [];
  for (const e of entries) {
    const last = groups[groups.length - 1];
    if (last && last.org === e.org) last.roles.push(e);
    else groups.push({ org: e.org, roles: [e], anchorEnd: 0, anchorStart: 0 });
  }
  for (const g of groups) {
    g.roles.sort(byRecentEnd);
    g.anchorEnd = Math.max(...g.roles.map((r) => monthKey(r.end)));
    g.anchorStart = Math.max(...g.roles.map((r) => monthKey(r.start)));
  }
  return groups.sort((a, b) => b.anchorEnd - a.anchorEnd || b.anchorStart - a.anchorStart);
}

const sections: { id: string; coords: string; title: string; groups: Group[] }[] = [
  { id: 'experience', coords: d.sections.experience[0], title: d.sections.experience[1], groups: groupEntries([cv.current as Entry, ...(cv.experience as Entry[])]) },
  { id: 'research', coords: d.sections.research[0], title: d.sections.research[1], groups: groupEntries(cv.research as Entry[]) },
  { id: 'education', coords: d.sections.education[0], title: d.sections.education[1], groups: groupEntries(cv.education as Entry[]) },
  { id: 'volunteering', coords: d.sections.volunteering[0], title: d.sections.volunteering[1], groups: groupEntries(cv.volunteering as Entry[]) },
];

// zh uses a data-driven array of groups (label + items); en keeps the legacy
// {data, frameworks, tools} object. Render handles both so each language's CV
// data can be maintained independently.
const sk = cv.skills as any;
const skillGroups: [string, string[]][] = Array.isArray(sk)
  ? (sk as { label: string; items: string[] }[]).map((g) => [g.label, g.items])
  : [
      [d.skillGroups.data, sk.data],
      [d.skillGroups.frameworks, sk.frameworks],
      [d.skillGroups.tools, sk.tools],
    ];
---

<Base title={d.title} description={d.desc}>
  <main class="mx-auto max-w-3xl px-6 pt-16 pb-8">
    <header>
      <p class="font-mono text-xs tracking-[0.2em] text-ink-muted uppercase reveal">{d.kicker}</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl reveal">{lang === 'zh' ? '李思高' : 'Sigao Li'}</h1>
      <p class="mt-4 text-ink-muted reveal">{d.intro}</p>
      <a
        href="/files/pdf/CV__Sigao_Li.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="reveal mt-6 inline-block rounded-full px-6 py-2.5 text-sm font-medium transition-opacity hover:opacity-85"
        style="background: var(--accent); color: var(--bg);"
      >
        {d.download}
      </a>
    </header>

    {sections.map((s) => (
      <section class="mt-20" id={s.id}>
        <SectionHeading title={s.title} />
        <div class="timeline relative mt-10 pl-10">
          <div class="absolute left-[5px] top-1 bottom-1 w-px" style="background: var(--line);" aria-hidden="true"></div>
          <div class="tl-progress absolute left-[4.5px] top-1 bottom-1 w-[2px] origin-top" style="background: var(--accent); transform: scaleY(0);" aria-hidden="true"></div>

          <ol class="space-y-12">
            {s.groups.map((g) => (
              <li class="tl-entry relative">
                <span class="tl-dot absolute -left-10 top-1.5 block h-[11px] w-[11px] rounded-full border-2"
                  style="border-color: var(--accent); background: var(--bg);" aria-hidden="true"></span>
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="font-display text-xl" style="color: var(--accent);">{g.org}</h3>
                  {g.roles[0].location && <span class="shrink-0 font-mono text-xs text-ink-muted">{g.roles[0].location}</span>}
                </div>
                {g.roles.length > 1 ? (
                  <div class="tl-subgroup relative mt-5">
                    <div class="tl-subrail absolute left-[3px] w-px" style="background: var(--line);" aria-hidden="true"></div>
                    <div class="tl-subline absolute left-[2.5px] w-[2px] origin-top" style="background: color-mix(in srgb, var(--accent) 55%, var(--bg)); transform: scaleY(0);" aria-hidden="true"></div>
                    <ol class="space-y-7">
                      {g.roles.map((r) => (
                        <li class="relative pl-7">
                          <span class="tl-subdot absolute left-0 top-1.5 block h-2 w-2 rounded-full border"
                            style="border-color: color-mix(in srgb, var(--accent) 55%, var(--bg)); background: var(--bg);" aria-hidden="true"></span>
                          <p class="font-mono text-xs text-ink-muted">{fmt(r.start)} — {fmt(r.end)}</p>
                          <h4 class="mt-0.5 text-base font-medium">{r.title}</h4>
                          {r.bullets.length > 0 && (
                            <ul class="mt-2 space-y-1.5 text-sm text-ink-muted">
                              {r.bullets.map((b) => <li class="pl-4 relative before:content-['·'] before:absolute before:left-0">{b}</li>)}
                            </ul>
                          )}
                        </li>
                      ))}
                    </ol>
                  </div>
                ) : (
                  <>
                    <p class="mt-1 font-mono text-xs text-ink-muted">
                      {fmt(g.roles[0].start)} — {fmt(g.roles[0].end)}
                    </p>
                    <h4 class="mt-0.5 text-base font-medium">{g.roles[0].title}</h4>
                    {g.roles[0].bullets.length > 0 && (
                      <ul class="mt-3 space-y-1.5 text-sm text-ink-muted">
                        {g.roles[0].bullets.map((b) => <li class="pl-4 relative before:content-['·'] before:absolute before:left-0">{b}</li>)}
                      </ul>
                    )}
                  </>
                )}
              </li>
            ))}
          </ol>
        </div>
      </section>
    ))}

    <section class="mt-20">
      <SectionHeading title={d.sections.awards[1]} />
      <ul class="mt-8 space-y-3">
        {cv.awards.map((a) => (
          <li class="reveal flex gap-5 text-sm">
            <span class="font-mono text-ink-muted shrink-0">{a.year}</span>
            <span>{a.title}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-20">
      <SectionHeading title={d.sections.skills[1]} />
      <div class="mt-8 space-y-5 reveal">
        {skillGroups.map(([group, items]) => (
          <div>
            <p class="font-mono text-xs text-ink-muted uppercase tracking-wider">{group}</p>
            <div class="mt-2 flex flex-wrap gap-2">
              {items.map((tag) => (
                <span class="rounded-full border px-3 py-1 text-xs" style="border-color: var(--line); background: var(--bg-elevated);">{tag}</span>
              ))}
            </div>
          </div>
        ))}
        <div>
          <p class="font-mono text-xs text-ink-muted uppercase tracking-wider">{d.skillGroups.certifications}</p>
          <ul class="mt-2 space-y-1 text-sm text-ink-muted">
            {cv.certifications.map((c) => <li>{c.title} — {c.org}</li>)}
          </ul>
        </div>
      </div>
    </section>
  </main>
</Base>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { pageScript, prefersReducedMotion } from '../../lib/motion';

  gsap.registerPlugin(ScrollTrigger);

  pageScript(() => {
    const timelines = document.querySelectorAll<HTMLElement>('.timeline');
    if (!timelines.length) return;

    // var() references stay correct across theme switches. Sub-group dots use a
    // lighter accent than the main timeline.
    const SUB_ACCENT = 'color-mix(in srgb, var(--accent) 55%, var(--bg))';
    const paint = (dot: Element, on: boolean, onColor = 'var(--accent)') => {
      (dot as HTMLElement).style.backgroundColor = on ? onColor : 'var(--bg)';
    };

    // Reduced motion: no scroll effects — only the first node is marked active.
    if (prefersReducedMotion()) {
      timelines.forEach((tl) => {
        const first = tl.querySelector('.tl-dot');
        if (first) paint(first, true);
      });
      return;
    }

    const ctx = gsap.context(() => {
      timelines.forEach((tl) => {
        const progress = tl.querySelector<HTMLElement>('.tl-progress');
        const dots = Array.from(tl.querySelectorAll<HTMLElement>('.tl-dot'));
        const subdots = Array.from(tl.querySelectorAll<HTMLElement>('.tl-subdot'));
        // Merged-org groups: each has its own sub-rail (gray) + sub progress line
        // (accent) that fills as the main line's tip passes through the group.
        const subgroups = Array.from(tl.querySelectorAll<HTMLElement>('.tl-subgroup')).map((el) => ({
          el,
          rail: el.querySelector<HTMLElement>('.tl-subrail'),
          line: el.querySelector<HTMLElement>('.tl-subline'),
          dots: Array.from(el.querySelectorAll<HTMLElement>('.tl-subdot')),
          startY: 0,
          endY: 0,
        }));

        // Line and dots are driven by one scrubbed progress value (0→1), so a
        // dot turns accent exactly when the growing line reaches its center —
        // and reverts to bg when the line retreats past it on scroll up. Sub-dots
        // and each group's sub-line are driven by the same tip, so the effect
        // continues into merged-org groups.
        let lineTop = 4; // top-1
        let lineH = 1; // top-1 + bottom-1
        let dotThresholds: number[] = [];
        let subThresholds: number[] = [];
        const centerY = (dot: HTMLElement, top: number) => {
          const r = dot.getBoundingClientRect();
          return r.top - top + r.height / 2;
        };
        const measure = () => {
          const top = tl.getBoundingClientRect().top;
          lineTop = 4;
          lineH = tl.offsetHeight - 8;
          const thr = (dot: HTMLElement) => Math.min(1, Math.max(0, (centerY(dot, top) - lineTop) / lineH));
          dotThresholds = dots.map((dot, i) => (i === 0 ? 0 : thr(dot)));
          subThresholds = subdots.map(thr);
          for (const sg of subgroups) {
            if (!sg.line || !sg.dots.length) continue;
            const first = sg.dots[0];
            const last = sg.dots[sg.dots.length - 1];
            const elTop = sg.el.getBoundingClientRect().top;
            const topRel = first.getBoundingClientRect().top - elTop + first.getBoundingClientRect().height / 2;
            const botRel = last.getBoundingClientRect().top - elTop + last.getBoundingClientRect().height / 2;
            const h = Math.max(0, botRel - topRel) + 'px';
            for (const seg of [sg.rail, sg.line]) {
              if (seg) { seg.style.top = topRel + 'px'; seg.style.height = h; }
            }
            sg.startY = centerY(first, top);
            sg.endY = centerY(last, top);
          }
        };
        const render = (p: number) => {
          const tipY = lineTop + p * lineH;
          if (progress) gsap.set(progress, { scaleY: p });
          dots.forEach((dot, i) => paint(dot, p >= dotThresholds[i]));
          subdots.forEach((dot, i) => paint(dot, p >= subThresholds[i], SUB_ACCENT));
          for (const sg of subgroups) {
            if (!sg.line) continue;
            const frac = sg.endY > sg.startY ? Math.min(1, Math.max(0, (tipY - sg.startY) / (sg.endY - sg.startY))) : 0;
            gsap.set(sg.line, { scaleY: frac });
          }
        };

        // Each section's line maps 1:1 to scroll as the section crosses the
        // viewport's vertical centre (the reading line). Because sections don't
        // overlap in the document, their scroll ranges are disjoint, so the lines
        // fill sequentially — research only begins once experience has scrolled
        // past. start is clamped to 0 so the first section is empty on load yet
        // has no dead zone; end uses the unclamped raw start so growth stays
        // anchored to the section's true extent (1:1, never compressed).
        const rawStart = () =>
          tl.getBoundingClientRect().top + window.scrollY - window.innerHeight * 0.5;
        const state = { p: 0 };
        gsap.to(state, {
          p: 1,
          ease: 'none',
          onUpdate: () => render(state.p),
          scrollTrigger: {
            start: () => Math.max(0, rawStart()),
            end: () => rawStart() + tl.offsetHeight,
            scrub: 0.6,
            invalidateOnRefresh: true,
            onRefresh: () => { measure(); render(state.p); },
          },
        });

        measure();
        render(0); // load: line collapsed, only the first node blue

        // Entry slide-in reveal (independent of the progress line).
        tl.querySelectorAll<HTMLElement>('.tl-entry').forEach((entry) => {
          gsap.from(entry, {
            x: -18, opacity: 0, duration: 0.55, ease: 'power2.out',
            scrollTrigger: { trigger: entry, start: 'top 82%', once: true },
          });
        });
      });
    });
    return () => ctx.revert();
  });
</script>
