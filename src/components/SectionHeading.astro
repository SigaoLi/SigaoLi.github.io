---
interface Props {
  coords?: string;
  title: string;
  id?: string;
}
const { coords, title, id } = Astro.props;
---

<div class="reveal" id={id}>
  {coords && <p class="font-mono text-xs tracking-[0.2em] text-ink-muted uppercase">{coords}</p>}
  <h2 class:list={['font-display text-3xl sm:text-4xl', coords && 'mt-3']}>{title}</h2>
</div>
