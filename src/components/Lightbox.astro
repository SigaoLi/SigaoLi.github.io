<!-- Photo lightbox: keyboard navigable, focus-trapped, scroll-locked.
     Backdrop is the page itself, frosted (blur) and dimmed with a faint accent
     wash, so the viewer feels part of the site rather than a black void. -->
<div
  id="lightbox"
  class="lb-overlay fixed inset-0 z-[60] hidden items-center justify-center"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <div id="lb-counter" class="absolute left-5 top-5 font-mono text-xs tracking-widest text-white/55"></div>
  <button id="lb-close" class="lb-btn absolute right-5 top-5" aria-label="Close viewer" title="Esc">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
  </button>
  <button id="lb-prev" class="lb-btn absolute left-3 sm:left-6" aria-label="Previous photo" title="←">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 5l-7 7 7 7"/></svg>
  </button>
  <figure id="lb-figure" class="flex max-h-[92svh] max-w-[92vw] flex-col items-center">
    <img id="lb-img" class="max-h-[82svh] max-w-[92vw] rounded-sm object-contain" src="" alt="" />
    <figcaption class="mt-5 max-w-[64ch] px-6 text-center">
      <span id="lb-desc" class="block font-display text-base leading-snug text-white/90 sm:text-lg"></span>
      <span id="lb-meta" class="mt-2.5 flex items-center justify-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-white/55"></span>
    </figcaption>
  </figure>
  <button id="lb-next" class="lb-btn absolute right-3 sm:right-6" aria-label="Next photo" title="→">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<style>
  .lb-overlay {
    background: color-mix(in srgb, var(--accent) 12%, rgb(10 12 16 / 0.8));
    backdrop-filter: blur(22px) saturate(1.1);
    -webkit-backdrop-filter: blur(22px) saturate(1.1);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .lb-overlay.lb-open { opacity: 1; }
  #lb-figure { transform: scale(0.97); transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .lb-overlay.lb-open #lb-figure { transform: scale(1); }
  #lb-img {
    box-shadow: 0 24px 60px -12px rgb(0 0 0 / 0.6);
    border: 1px solid rgb(255 255 255 / 0.1);
  }
  /* dot motif separator between place and coordinates */
  #lb-meta .sep { width: 3px; height: 3px; border-radius: 50%; background: var(--accent); display: inline-block; }
  .lb-btn {
    display: grid; place-items: center; width: 40px; height: 40px; border-radius: 9999px;
    color: rgb(255 255 255 / 0.75); background: rgb(255 255 255 / 0.06);
    backdrop-filter: blur(4px); cursor: pointer; transition: background 0.2s, color 0.2s, transform 0.1s;
  }
  .lb-btn:hover { color: #fff; background: rgb(255 255 255 / 0.14); }
  /* 交互打磨(07-19):按下微缩反馈 */
  .lb-btn:active { transform: scale(0.92); }
  @media (prefers-reduced-motion: reduce) {
    .lb-overlay, #lb-figure { transition: none; }
    .lb-btn:active { transform: none; }
  }
</style>

<script>
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  pageScript(() => {
    const lb = document.getElementById('lightbox');
    if (!lb) return;
    const imgEl = document.getElementById('lb-img') as HTMLImageElement;
    const descEl = document.getElementById('lb-desc')!;
    const metaEl = document.getElementById('lb-meta')!;
    const counterEl = document.getElementById('lb-counter')!;
    const btnClose = document.getElementById('lb-close')!;
    const btnPrev = document.getElementById('lb-prev')!;
    const btnNext = document.getElementById('lb-next')!;

    const items = [...document.querySelectorAll<HTMLElement>('[data-lightbox]')];
    if (!items.length) return;

    let idx = -1;
    let lastFocus: HTMLElement | null = null;
    let loadToken = 0;
    let closeTimer = 0;

    const show = (i: number) => {
      idx = (i + items.length) % items.length;
      const el = items[idx];
      const full = el.dataset.full!;
      const token = ++loadToken;
      // Show the already-cached thumbnail immediately, swap in the 2048px
      // image once it has loaded (token guards against fast navigation).
      const thumb = el.querySelector('img')?.currentSrc;
      imgEl.src = thumb || full;
      if (thumb && thumb !== full) {
        const loader = new Image();
        loader.onload = () => { if (token === loadToken) imgEl.src = full; };
        loader.src = full;
      }
      imgEl.alt = el.dataset.alt ?? '';
      descEl.textContent = el.dataset.alt ?? '';
      // place (city · country) + coordinates, joined by a dot-motif separator
      const place = [el.dataset.city, el.dataset.label].filter(Boolean).join(' · ');
      const coords = el.dataset.coords ?? '';
      metaEl.innerHTML = '';
      const add = (text: string) => { const s = document.createElement('span'); s.textContent = text; metaEl.appendChild(s); };
      const sep = () => { const s = document.createElement('span'); s.className = 'sep'; metaEl.appendChild(s); };
      if (place) add(place);
      if (coords) { if (place) sep(); add(coords); }
      counterEl.textContent = `${idx + 1} / ${items.length}`;
      // Preload neighbours
      for (const n of [idx + 1, idx - 1]) {
        const p = new Image();
        p.src = items[(n + items.length) % items.length].dataset.full!;
      }
    };

    const open = (i: number) => {
      clearTimeout(closeTimer);
      lastFocus = document.activeElement as HTMLElement;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      show(i);
      requestAnimationFrame(() => lb.classList.add('lb-open'));
      btnClose.focus();
    };

    const close = () => {
      lb.classList.remove('lb-open');
      document.body.style.overflow = '';
      const finish = () => { lb.classList.add('hidden'); lb.classList.remove('flex'); imgEl.src = ''; };
      clearTimeout(closeTimer);
      if (prefersReducedMotion()) finish();
      else closeTimer = window.setTimeout(finish, 300);
      lastFocus?.focus();
    };

    const handlers: Array<[EventTarget, string, EventListener]> = [];
    const on = (el: EventTarget, ev: string, fn: EventListener) => {
      el.addEventListener(ev, fn);
      handlers.push([el, ev, fn]);
    };

    items.forEach((el, i) => {
      on(el, 'click', (() => open(i)) as EventListener);
      on(el, 'keydown', ((e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') { ke.preventDefault(); open(i); }
      }) as EventListener);
    });

    on(btnClose, 'click', close as EventListener);
    on(btnPrev, 'click', (() => show(idx - 1)) as EventListener);
    on(btnNext, 'click', (() => show(idx + 1)) as EventListener);
    on(lb, 'click', ((e: Event) => { if (e.target === lb) close(); }) as EventListener);

    on(document, 'keydown', ((e: Event) => {
      if (lb.classList.contains('hidden')) return;
      const ke = e as KeyboardEvent;
      if (ke.key === 'Escape') close();
      else if (ke.key === 'ArrowLeft') show(idx - 1);
      else if (ke.key === 'ArrowRight') show(idx + 1);
      else if (ke.key === 'Tab') {
        // Simple focus trap across the three buttons
        const focusables = [btnPrev, btnClose, btnNext];
        const cur = focusables.indexOf(document.activeElement as HTMLButtonElement);
        ke.preventDefault();
        const next = ke.shiftKey ? (cur <= 0 ? focusables.length - 1 : cur - 1) : (cur + 1) % focusables.length;
        focusables[next].focus();
      }
    }) as EventListener);

    return () => {
      handlers.forEach(([el, ev, fn]) => el.removeEventListener(ev, fn));
      document.body.style.overflow = '';
    };
  });
</script>
