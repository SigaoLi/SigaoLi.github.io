<!-- Photo lightbox: keyboard navigable, focus-trapped, scroll-locked. -->
<div
  id="lightbox"
  class="fixed inset-0 z-[60] hidden items-center justify-center"
  style="background: rgb(10 10 9 / 0.94);"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <button id="lb-close" class="absolute right-5 top-5 p-2 text-white/70 hover:text-white cursor-pointer" aria-label="Close viewer">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
  </button>
  <button id="lb-prev" class="absolute left-3 sm:left-6 p-3 text-white/70 hover:text-white cursor-pointer" aria-label="Previous photo">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 5l-7 7 7 7"/></svg>
  </button>
  <figure class="flex max-h-[92svh] max-w-[92vw] flex-col items-center">
    <img id="lb-img" class="max-h-[85svh] max-w-[92vw] rounded object-contain" src="" alt="" />
    <figcaption id="lb-caption" class="mt-3 font-mono text-xs text-white/60"></figcaption>
  </figure>
  <button id="lb-next" class="absolute right-3 sm:right-6 p-3 text-white/70 hover:text-white cursor-pointer" aria-label="Next photo">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<script>
  import { pageScript } from '../lib/motion';

  pageScript(() => {
    const lb = document.getElementById('lightbox');
    if (!lb) return;
    const imgEl = document.getElementById('lb-img') as HTMLImageElement;
    const caption = document.getElementById('lb-caption')!;
    const btnClose = document.getElementById('lb-close')!;
    const btnPrev = document.getElementById('lb-prev')!;
    const btnNext = document.getElementById('lb-next')!;

    const items = [...document.querySelectorAll<HTMLElement>('[data-lightbox]')];
    if (!items.length) return;

    let idx = -1;
    let lastFocus: HTMLElement | null = null;

    const show = (i: number) => {
      idx = (i + items.length) % items.length;
      const el = items[idx];
      imgEl.src = el.dataset.full!;
      imgEl.alt = el.dataset.alt ?? '';
      caption.textContent = `${el.dataset.label} · ${idx + 1} / ${items.length}`;
      // Preload neighbours
      for (const n of [idx + 1, idx - 1]) {
        const p = new Image();
        p.src = items[(n + items.length) % items.length].dataset.full!;
      }
    };

    const open = (i: number) => {
      lastFocus = document.activeElement as HTMLElement;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      show(i);
      btnClose.focus();
    };

    const close = () => {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
      imgEl.src = '';
      lastFocus?.focus();
    };

    const handlers: Array<[EventTarget, string, EventListener]> = [];
    const on = (el: EventTarget, ev: string, fn: EventListener) => {
      el.addEventListener(ev, fn);
      handlers.push([el, ev, fn]);
    };

    items.forEach((el, i) => {
      on(el, 'click', (() => open(i)) as EventListener);
      on(el, 'keydown', ((e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') { ke.preventDefault(); open(i); }
      }) as EventListener);
    });

    on(btnClose, 'click', close as EventListener);
    on(btnPrev, 'click', (() => show(idx - 1)) as EventListener);
    on(btnNext, 'click', (() => show(idx + 1)) as EventListener);
    on(lb, 'click', ((e: Event) => { if (e.target === lb) close(); }) as EventListener);

    on(document, 'keydown', ((e: Event) => {
      if (lb.classList.contains('hidden')) return;
      const ke = e as KeyboardEvent;
      if (ke.key === 'Escape') close();
      else if (ke.key === 'ArrowLeft') show(idx - 1);
      else if (ke.key === 'ArrowRight') show(idx + 1);
      else if (ke.key === 'Tab') {
        // Simple focus trap across the three buttons
        const focusables = [btnPrev, btnClose, btnNext];
        const cur = focusables.indexOf(document.activeElement as HTMLButtonElement);
        ke.preventDefault();
        const next = ke.shiftKey ? (cur <= 0 ? focusables.length - 1 : cur - 1) : (cur + 1) % focusables.length;
        focusables[next].focus();
      }
    }) as EventListener);

    return () => {
      handlers.forEach(([el, ev, fn]) => el.removeEventListener(ev, fn));
      document.body.style.overflow = '';
    };
  });
</script>
