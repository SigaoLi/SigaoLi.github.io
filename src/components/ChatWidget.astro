---
// 全站右下角 AI 聊天浮窗(PRD §22,V1)。
// 入口=数字门童 Zoe(PRD §23,2026-07-14 动作系统实装):全站固定右下角,零走位;
// - 跨页 transition:persist:切页原地不断帧,睡眠状态延续;切页瞬间抽「切页反应」(18/19/20)
// - 静默层:idle 常驻(定格静息⇄间歇播放,拉开眨眼/眯眼间隔);75s 无活动入睡(坐→趴),hover/点击/聊天才醒(滚动不吵醒);23-6 点进站已睡
// - 微动层:舔爪/打哈欠 2-3 分钟低频随机,滚动中绝不播,同一动作不连播
// - 互动层:hover=唤醒/逗猫计数;打字=倾听;等首 token=歪头思考;流式回复=敲地面⇄傲娇随机轮换(播完当前段切回)
//   (07-15 Sigao 定「移动非叠加」:凑近看你只在切页反应池,傲娇只在打字轮换)
// - 彩蛋层(每会话各一次):睡醒伸懒腰替普通起身;回头客挥手;连续逗猫 3 次玩球;道谢/道别作揖
// 素材=锚点图为节点、片段为边(首尾帧钉死故硬切连贯),生产手册 docs/zoe-production-handbook.md。
// 前端只认 api.sigaoli.com(可迁移性约束);流式用 fetch+getReader 解析 SSE(EventSource 不支持 POST)。
import { t, localizePath, type Lang } from '../lib/i18n';
import { site } from '../lib/site';

const lang: Lang = Astro.currentLocale === 'zh' ? 'zh' : 'en';
const d = t(lang).chat;
const apiBase = import.meta.env.DEV ? 'http://localhost:8787' : site.api;
const privacyHref = localizePath(lang, '/privacy');
// 意图引导 chip 配置(§23.5):label=Zoe 口吻文案,href=本地化版块路径 / mailto。分类器只回 chip 键名。
const guides = JSON.stringify({
  work: { label: d.guide.work, href: localizePath(lang, '/work') },
  cv: { label: d.guide.cv, href: localizePath(lang, '/cv') },
  photography: { label: d.guide.photography, href: localizePath(lang, '/photography') },
  email: { label: d.guide.email, href: `mailto:${site.email}` },
});
---

<div id="chat-root" data-lang={lang} data-api={apiBase} data-greeting={d.greeting} data-guides={guides}
  data-bubble={d.bubble} data-meow={d.meow} data-open={d.open} data-forgotten={d.forgotten}
  data-welcome-back={d.welcomeBack} data-ask-name={d.askName} data-name-ack={d.nameAck}
  data-err-rate={d.errRate} data-err-turns={d.errTurns} data-err-upstream={d.errUpstream} data-err-network={d.errNetwork}>
  <!-- Zoe 舞台:零尺寸锚点按钮,子元素 bottom:0 对齐脚底地面线;transform 定位右下角。
       transition:persist=跨页保留 DOM,视频不断帧(语言切换时面板重建、舞台沿用,标签由 JS 同步) -->
  <button id="chat-fab" transition:persist="zoe-stage" aria-label={d.open} title={d.open} aria-expanded="false" aria-controls="chat-panel"
    class="zoe-stage fixed left-0 top-0 z-[59]">
    <video id="zoe-a" muted playsinline aria-hidden="true"></video>
    <video id="zoe-b" muted playsinline aria-hidden="true"></video>
    <img id="zoe-still" src="/zoe/zoe-sit.webp" alt="" hidden style="height:150px" aria-hidden="true" />
    <span id="zoe-bubble" hidden aria-hidden="true">{d.bubble}</span>
  </button>

  <!-- 对话面板 -->
  <!-- 桌面端面板让位到 Zoe 左侧(Sigao 07-12 定:Zoe 在对话框右侧);移动端仍贴右、盖住 Zoe -->
  <section id="chat-panel" role="dialog" aria-label={d.title} hidden
    class="fixed bottom-20 right-5 z-[60] flex w-[min(380px,calc(100vw-2.5rem))] flex-col overflow-hidden rounded-xl border shadow-2xl md:bottom-5 md:right-[11.25rem]"
    style="border-color: var(--line); background: var(--bg-elevated); height: min(540px, calc(100dvh - 8.5rem));">
    <header class="border-b px-4 py-3" style="border-color: var(--line);">
      <p class="font-mono text-[10px] uppercase tracking-wider" style="color: var(--accent);">{d.title}</p>
      <p class="mt-0.5 text-xs text-ink-muted">{d.subtitle}</p>
    </header>

    <div id="chat-log" role="log" aria-live="polite" class="flex-1 space-y-3 overflow-y-auto px-4 py-4"></div>

    <!-- 常用问题(仅空对话时显示,点击即发送) -->
    <div id="chat-suggest" class="flex flex-wrap gap-1.5 px-4 pb-2">
      {t(lang).chat.suggestions.map((q) => (
        <button type="button" class="chat-chip rounded-full border px-2.5 py-1 text-left text-xs transition-colors">{q}</button>
      ))}
    </div>

    <form id="chat-form" class="border-t px-3 py-3" style="border-color: var(--line);">
      <div class="flex items-end gap-2">
        <textarea id="chat-input" rows="1" maxlength="2000" placeholder={d.placeholder} autocomplete="off"
          class="max-h-28 w-full resize-none bg-transparent px-1 py-1.5 text-sm outline-none text-ink placeholder:text-ink-muted"></textarea>
        <button id="chat-send" type="submit" aria-label={d.send}
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-white transition-opacity disabled:opacity-40"
          style="background: var(--accent);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m5 12 14 0M13 6l6 6-6 6"/>
          </svg>
        </button>
      </div>
      <div class="mt-2 flex items-center justify-between gap-2">
        <p class="text-[10px] leading-tight text-ink-muted">
          {d.disclaimer}
          <a href={privacyHref} class="underline underline-offset-2 hover:text-ink">{d.privacy}</a>
        </p>
        <div class="flex shrink-0 items-center gap-2">
          <button id="zoe-forget" type="button" class="font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-ink">{d.forget}</button>
          <button id="chat-reset" type="button" class="font-mono text-[10px] uppercase tracking-wider text-ink-muted hover:text-ink">{d.reset}</button>
        </div>
      </div>
    </form>
  </section>
</div>

<style>
  .chat-chip { border-color: var(--line); color: var(--ink-muted); }
  .chat-chip:hover { border-color: var(--accent); color: var(--ink); }
  /* 实体碰撞盒 160×180,margin 负偏移使 transform 锚点=脚底中心(零尺寸盒会被点击/无障碍工具忽略) */
  .zoe-stage { background: none; border: none; padding: 0; cursor: pointer; will-change: transform; pointer-events: auto;
    width: 160px; height: 180px; margin-left: -80px; margin-top: -180px; }
  .zoe-stage video, .zoe-stage img {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    max-width: none; /* 默认 video max-width:100% 会把宽画幅片段压进 160px 碰撞盒 → 猫缩小(07-12 尺寸 bug 根因) */
    display: none;
    filter: drop-shadow(0 5px 12px rgb(0 0 0 / 0.16));
  }
  .zoe-stage .on { display: block; }
  .zoe-stage:focus-visible video, .zoe-stage:focus-visible img { outline: 2px solid var(--accent); outline-offset: 4px; border-radius: 8px; }
  /* 问候/喵~ 气泡:锚在猫头上方,尾巴指向她;点击(冒泡到按钮)即开聊 */
  #zoe-bubble {
    position: absolute; right: 4px; bottom: calc(100% + 12px);
    max-width: 180px; width: max-content; text-align: left; /* 230→180:配合头像左移/Zoe 右移,紧凑视口不遮社交图标 */
    padding: 0.5rem 0.75rem; border-radius: 0.75rem; border-bottom-right-radius: 2px;
    border: 1px solid var(--line); background: var(--bg-elevated); color: var(--ink);
    font-size: 0.8rem; line-height: 1.5; box-shadow: 0 6px 20px rgb(0 0 0 / 0.12);
    transform-origin: 90% 100%; animation: zoe-bubble-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  #zoe-bubble::after {
    content: ''; position: absolute; right: 18px; bottom: -5px; width: 10px; height: 10px;
    background: var(--bg-elevated); border-right: 1px solid var(--line); border-bottom: 1px solid var(--line);
    transform: rotate(45deg);
  }
  #zoe-bubble[hidden] { display: none; }
  @keyframes zoe-bubble-pop { from { opacity: 0; transform: scale(0.6); } to { opacity: 1; transform: scale(1); } }
  @media (prefers-reduced-motion: reduce) { #zoe-bubble { animation: none; } }
</style>

<!-- 气泡由运行时 JS 创建,拿不到 Astro 作用域属性,样式须 is:global -->
<style is:global>
  .chat-msg { max-width: 85%; border-radius: 0.75rem; padding: 0.5rem 0.75rem; font-size: 0.875rem; line-height: 1.55; overflow-wrap: anywhere; }
  .chat-msg.user { margin-left: auto; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--ink); }
  .chat-msg.bot { margin-right: auto; border: 1px solid var(--line); background: var(--bg); color: var(--ink); }
  .chat-msg.bot code { font-family: var(--font-mono, monospace); font-size: 0.8em; background: color-mix(in srgb, var(--line) 45%, transparent); border-radius: 3px; padding: 0 3px; }
  .chat-msg.pending::after { content: '…'; opacity: 0.5; }
  /* 意图引导 chip:回复下方可点的版块导航/邮箱(§23.5) */
  .chat-guide { margin-right: auto; }
  .chat-guide-chip {
    display: inline-flex; align-items: center; gap: 0.25rem;
    border: 1px solid var(--line); border-radius: 9999px;
    padding: 0.3rem 0.75rem; font-size: 0.8rem; line-height: 1.2;
    color: var(--accent); text-decoration: none; white-space: nowrap;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .chat-guide-chip:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); }
</style>

<script>
  import { pageScript } from '../lib/motion';

  const MAX_TURNS = 12; // 与 worker/src/core/config.ts 的 maxTurns 一致
  type Msg = { role: 'user' | 'assistant'; content: string };

  const store = {
    load: (): Msg[] => { try { return JSON.parse(sessionStorage.getItem('sigaoli-chat') ?? '[]'); } catch { return []; } },
    save: (h: Msg[]) => sessionStorage.setItem('sigaoli-chat', JSON.stringify(h)),
    clear: () => sessionStorage.removeItem('sigaoli-chat'),
  };

  // 回头客画像(§23.5 记忆):只存访客本地设备(localStorage),你不持有;可一键「忘记我」清 sigaoli-zoe-*。
  // v1 只用于问候认人(名字不进 /chat 提示词,零注入面);后续可加兴趣追踪 + 注入。
  type Profile = { name?: string; visits: number; lastVisit?: string; askCount?: number };
  const profile = {
    data: { visits: 0 } as Profile,
    load() {
      try { this.data = { visits: 0, ...JSON.parse(localStorage.getItem('sigaoli-zoe-profile') ?? '{}') }; }
      catch { this.data = { visits: 0 }; }
      return this.data;
    },
    save() { try { localStorage.setItem('sigaoli-zoe-profile', JSON.stringify(this.data)); } catch { /* 隐私模式可拒 */ } },
  };

  // ---- Zoe 片段清单(素材 public/zoe/,600p VP9 alpha;管线 scripts/zoe-prod2.mjs,手册 docs/zoe-production-handbook.md) ----
  // 锚点图结构:所有片段首尾帧钉在 坐(a-sit2)/趴(b-loaf2) 锚点上 → 任意组合硬切即连贯;
  // loop 片段(首=尾)天然无缝;listen/think/type 首尾也是锚点,可动态开 loop 循环。
  type ZoeClip = { src: string; loop?: boolean };
  const ZOE: Record<string, ZoeClip> = {
    idle: { src: 'idle', loop: true },
    loaf: { src: 'loaf', loop: true },
    loafToSit: { src: 'loaf-to-sit' },
    sitToLoaf: { src: 'sit-to-loaf' },
    stretch: { src: 'stretch' },
    attend: { src: 'attend' },
    listen: { src: 'listen', loop: true },
    think: { src: 'think', loop: true },
    type: { src: 'type', loop: true },
    groom: { src: 'groom' },
    yawn: { src: 'yawn' },
    wave: { src: 'wave' },
    ball: { src: 'ball' },
    bow: { src: 'bow' },
    proud: { src: 'proud' },
    startle: { src: 'startle' },
    earflick: { src: 'earflick' },
    glance: { src: 'glance' },
  };

  // 计时旋钮(PRD §23.2);?zoe-fast 把分钟级等待缩到秒级(本地验收/E2E 用,不影响正常访客)
  const FAST = new URLSearchParams(location.search).has('zoe-fast');
  const T = {
    loafDwell: 2000,                      // 进场秀起身前趴着停留
    sleepAfter: FAST ? 6_000 : 75_000,    // 无活动入睡(60-90s 取中)
    microMin: FAST ? 10_000 : 120_000,    // 微动间隔 2-3 分钟
    microMax: FAST ? 15_000 : 180_000,
    scrollQuiet: FAST ? 2_000 : 8_000,    // 滚动停止多久后才允许自发动作
    switchNone: FAST ? 1_000 : 8_000,     // 切页反应:间隔内不出动作
    switchSmall: FAST ? 5_000 : 30_000,   // 切页反应:间隔内只出小动作
    ballWindow: 45_000,                   // 连续逗猫计数窗口
    idleRestMin: FAST ? 2_000 : 5_000,    // idle 静息定格时长(眯眼间隔≈静息+一次播放5s)
    idleRestMax: FAST ? 4_000 : 10_000,
    nameWindow: FAST ? 30_000 : 120_000,  // 问名后多久内的回复才当名字应答(过期静默作罢,不误判)
  };
  // 彩蛋触发词(道谢/道别→作揖 bow,每会话一次;傲娇已移至打字轮换不再当彩蛋,07-15 Sigao 定)
  const THANKS_RE = /谢谢|谢啦|谢了|感谢|多谢|辛苦|thank|thx/i;
  const BYE_RE = /再见|拜拜|回见|告辞|晚安|下次聊|goodbye|\bbye\b|see you|farewell|good night/i;

  // ---- 模块级单例:transition:persist 下模块只执行一次,状态跨页存活;pageScript 每页只做接线 ----
  const Z = {
    booted: false,
    interactive: false, // 桌面+精细指针+非 reduced;false 时只有 idle,一律不加戏(§23 移动端/无障碍)
    reduced: false,
    vids: [] as HTMLVideoElement[],
    still: null as HTMLImageElement | null,
    fab: null as HTMLElement | null,
    bubbleEl: null as HTMLElement | null,
    cur: 0,
    gen: 0,
    state: 'boot' as 'boot' | 'show' | 'idle' | 'sleep' | 'wake' | 'listen' | 'think' | 'type' | 'act',
    lastActivity: Date.now(),
    lastScroll: 0,
    lastSwitch: 0,
    lastAuto: 0,      // 上次自发/互动动作(全局频率闸)
    lastMicro: '',
    hovers: [] as number[],
    pendingEgg: '' as '' | 'bow',
    awaitingName: false, // 已问名、等访客下一条消息作答(§23.5 回头客问名)
    askNameAt: 0,        // 问名时刻;超过 T.nameWindow 未答即作罢(不误把后来的提问当名字)
    sleepTimer: 0 as ReturnType<typeof setTimeout> | 0,
    microTimer: 0 as ReturnType<typeof setTimeout> | 0,
    idleTimer: 0 as ReturnType<typeof setTimeout> | 0,
    listenTimer: 0 as ReturnType<typeof setTimeout> | 0,
    bubbleTimer: 0 as ReturnType<typeof setTimeout> | 0,
  };
  let history: Msg[] = [];
  let busy = false;
  let aborter: AbortController | null = null;
  let guideEl: HTMLElement | null = null; // 当前引导 chip(只保留最新一条,§23.5)

  const $ = (id: string) => document.getElementById(id);
  const rootData = () => ($('chat-root')?.dataset ?? {}) as Record<string, string>;
  const panelOpen = () => { const p = $('chat-panel'); return !!p && !p.hidden; };
  const eggUsed = (k: string) => sessionStorage.getItem(`sigaoli-zoe-egg-${k}`) === '1';
  const useEgg = (k: string) => sessionStorage.setItem(`sigaoli-zoe-egg-${k}`, '1');
  const warm = (names: string[]) => { for (const n of names) { try { void fetch(`/zoe/${n}.webm`); } catch { /* 预热失败不致命 */ } } };

  // 使用量埋点:走站点既有 GoatCounter,只记事件名,不含对话内容;dev 构建不上报
  const track = (name: string) => {
    if (!import.meta.env.PROD) return;
    (window as unknown as { goatcounter?: { count?: (o: object) => void } }).goatcounter?.count?.({ path: name, event: true });
  };

  // 极简安全渲染:先转义 HTML,再恢复 **粗体** / `代码` / 换行
  const render = (text: string): string =>
    text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\n/g, '<br>');

  // ================= Zoe 播放引擎 =================
  const place = () => { if (Z.fab) Z.fab.style.transform = `translate3d(${innerWidth - 94}px, ${innerHeight - 28}px, 0)`; };
  const showEl = (el: HTMLElement) => {
    el.classList.add('on');
    for (const e of [...Z.vids, Z.still!]) if (e && e !== el) e.classList.remove('on');
  };
  const prepOn = (v: HTMLVideoElement, name: string): Promise<HTMLVideoElement> => {
    const url = `/zoe/${ZOE[name].src}.webm`;
    if (v.src.endsWith(url)) v.currentTime = 0;
    else v.src = url;
    v.style.height = '180px'; v.style.bottom = '-15px'; // 幅底距脚底 1/12
    return new Promise((res) => {
      if (v.readyState >= 3) res(v);
      else v.addEventListener('canplay', () => res(v), { once: true });
    });
  };
  // 元素复用策略:优先留在已装同片段的元素上(免重载)
  const prep = (name: string): Promise<HTMLVideoElement> => {
    let v = Z.vids[Z.cur];
    if (!v.src.endsWith(`/zoe/${ZOE[name].src}.webm`)) v = Z.vids[Z.cur ^= 1];
    return prepOn(v, name);
  };
  // 播放一段;非 loop 段 resolve 于 ended;gen 变化(被新动作打断)即中止
  // loopOverride: 首尾=锚点的片段都可无缝循环,按场景临时开(如傲娇在打字阶段循环、彩蛋时单次)
  const playZ = async (name: string, g: number, loopOverride?: boolean) => {
    const v = await prep(name);
    if (g !== Z.gen) return;
    v.loop = loopOverride ?? !!ZOE[name].loop;
    void v.play(); showEl(v);
    if (v.loop) return;
    await new Promise((r) => v.addEventListener('ended', r, { once: true }));
  };
  const showBubble = (text: string, ms: number) => {
    const bub = Z.bubbleEl;
    if (!bub) return;
    bub.textContent = text;
    bub.hidden = false;
    clearTimeout(Z.bubbleTimer);
    Z.bubbleTimer = setTimeout(() => { bub.hidden = true; }, ms);
  };
  // 「忘记我」(隐私):清掉本站在你设备上留的 Zoe 记忆——现仅回头客标记 sigaoli-zoe-seen,
  // Stage 3 的画像 sigaoli-zoe-profile 同前缀一并清。只动 localStorage,不碰当前对话(那是「重新开聊」)。
  const forgetVisitor = () => {
    try {
      for (const k of Object.keys(localStorage)) {
        if (k.startsWith('sigaoli-zoe')) localStorage.removeItem(k);
      }
    } catch { /* 隐私模式可拒 */ }
    profile.data = { visits: 0 }; // 同步清内存态,否则本会话 Zoe 还记得名字
    Z.awaitingName = false;
    showBubble(rootData().forgotten ?? '', 3200);
  };

  // ================= 状态编排(触发矩阵 PRD §23.2) =================
  const markActivity = () => { Z.lastActivity = Date.now(); };
  const scheduleSleep = () => {
    clearTimeout(Z.sleepTimer);
    if (!Z.interactive) return;
    const gap = T.sleepAfter - (Date.now() - Z.lastActivity);
    Z.sleepTimer = setTimeout(() => {
      if (Date.now() - Z.lastActivity < T.sleepAfter) { scheduleSleep(); return; }
      // 面板开着(在聊/在读)或不在 idle(在演出)则顺延
      if (Z.state === 'idle' && !panelOpen()) void fallAsleep();
      else scheduleSleep();
    }, Math.max(gap, 1000));
  };
  // idle 呼吸循环:定格首帧「静息」几秒 → 完整播一次(呼吸/眨眼/摆尾) → 再静息,如此往复。
  // (07-15 Sigao:idle 片段自带 ~1.7s 长眯眼,连续循环时眯眼显得太频繁 → 拉开播放间隔降低眯眼频次。
  //  用视频自身首帧定格、不切 webp:静息帧即末帧=首帧锚点,零跳变、无镜像方向/构图不一致风险)
  const idleRest = async (g: number) => {
    const v = await prep('idle');
    if (g !== Z.gen) return;
    v.loop = false; v.currentTime = 0; v.pause(); showEl(v); // 先定格首帧(睁眼锚点)
    for (;;) {
      await new Promise((r) => { Z.idleTimer = setTimeout(r, T.idleRestMin + Math.random() * (T.idleRestMax - T.idleRestMin)); });
      if (g !== Z.gen) return; // 被动作/入睡打断(gen 变)即退出,不清 timer 交由 gen 闸兜底
      await playZ('idle', g, false); // 播一次即停在末帧(=首帧锚点),下一轮静息无缝接续
      if (g !== Z.gen) return;
    }
  };
  const enterIdle = () => {
    const g = ++Z.gen;
    Z.state = 'idle';
    Z.lastActivity = Date.now(); // 入睡倒计时从「坐定」起算——刚演完动作 1 秒就睡显得突兀
    void idleRest(g);
    scheduleSleep();
  };
  const fallAsleep = async () => {
    const g = ++Z.gen;
    Z.state = 'sleep';
    warm(['stretch', 'loaf-to-sit']); // 醒来要用
    await playZ('sitToLoaf', g);
    if (g !== Z.gen) return;
    void playZ('loaf', g);
  };
  // 醒来:首次(每会话)伸懒腰彩蛋,其余普通起身;滚动不吵醒(不在唤醒触发源里)
  const wake = async (after?: () => void) => {
    if (Z.state !== 'sleep') return;
    const g = ++Z.gen;
    Z.state = 'wake';
    const stretch = !eggUsed('stretch');
    if (stretch) useEgg('stretch');
    await playZ(stretch ? 'stretch' : 'loafToSit', g);
    if (g !== Z.gen) return;
    enterIdle();
    after?.();
  };
  // 一次性动作(微动/彩蛋/切页反应):播完回 idle;startle 中段配「喵~」字气泡(无声视觉喵)
  const act = async (name: string) => {
    const g = ++Z.gen;
    Z.state = 'act';
    Z.lastAuto = Date.now();
    if (name === 'startle') {
      setTimeout(() => { if (g === Z.gen) showBubble(rootData().meow ?? '喵~', 1800); }, 3000);
    }
    await playZ(name, g);
    Z.lastAuto = Date.now(); // 间隔闸从动作「结束」重算——否则长片段(玩球 10s)播完即刻够格,微动会抢在入睡前插队
    if (g !== Z.gen) return;
    enterIdle();
  };
  // 微动调度:2-3 分钟一次,仅 idle+滚动停止+页面可见;舔爪/哈欠交替不连播
  const scheduleMicro = () => {
    clearTimeout(Z.microTimer);
    if (!Z.interactive) return;
    Z.microTimer = setTimeout(() => {
      const quiet = Date.now() - Z.lastScroll > T.scrollQuiet;
      const spaced = Date.now() - Z.lastAuto > T.microMin; // 全局自发频率闸
      if (Z.state === 'idle' && quiet && spaced && document.visibilityState === 'visible') {
        const pick = Z.lastMicro === 'groom' ? 'yawn' : Z.lastMicro === 'yawn' ? 'groom' : Math.random() < 0.5 ? 'groom' : 'yawn';
        Z.lastMicro = pick;
        void act(pick);
      }
      scheduleMicro();
    }, T.microMin + Math.random() * (T.microMax - T.microMin));
  };
  // 切页反应池:大(慌张四顾+喵)~2 成 / 小(竖耳眨眼、侧瞥、凑近看你)均分其余(凑近 07-15 Sigao 加入)
  // 防打扰闸:睡着/在演不反应;8s 内再切不出;30s 内连切或面板开着只出小动作
  const pageSwitchReaction = () => {
    const since = Date.now() - Z.lastSwitch;
    Z.lastSwitch = Date.now();
    if (!Z.interactive || Z.state !== 'idle') return;
    if (since < T.switchNone) return;
    const smallOnly = since < T.switchSmall || panelOpen();
    if (!smallOnly && Math.random() < 0.2) { void act('startle'); return; }
    const pool = ['earflick', 'glance', 'attend'];
    void act(pool[Math.floor(Math.random() * pool.length)]);
  };
  // hover:睡→醒;idle→只做逗猫计数,连续 3 次(45s 窗口)→玩球彩蛋
  // (凑近看你已移至切页反应池,hover 不再演,07-15 Sigao 定「移动非叠加」)
  const onStageEnter = () => {
    if (!Z.interactive) return;
    markActivity();
    if (Z.state === 'sleep') { void wake(); return; }
    if (Z.state !== 'idle') return;
    const now = Date.now();
    if (now - (Z.hovers[Z.hovers.length - 1] ?? 0) < 1000) return; // 边缘抖动去重
    Z.hovers = Z.hovers.filter((t) => now - t < T.ballWindow);
    Z.hovers.push(now);
    if (Z.hovers.length >= 3 && !eggUsed('ball')) { useEgg('ball'); Z.hovers = []; void act('ball'); }
  };
  // 进场秀:趴→起身坐好→(回头客加挥手)→idle+问候气泡;每会话一次,期间即可点击开聊
  const entryShow = async (returning: boolean) => {
    const g = ++Z.gen;
    Z.state = 'show';
    sessionStorage.setItem('sigaoli-zoe-shown', '1'); // 开演即记名,切页不复演
    place();
    warm(['loaf-to-sit', 'idle']);
    await playZ('loaf', g);
    await new Promise((r) => setTimeout(r, T.loafDwell)); if (g !== Z.gen) return;
    await playZ('loafToSit', g); if (g !== Z.gen) return;
    if (returning && !eggUsed('wave')) { useEgg('wave'); await playZ('wave', g); if (g !== Z.gen) return; }
    enterIdle();
    // 落座问候(面板已开=演出期间点开,则不冒):认识的老朋友直呼其名;回头且没留名 → 主动问名(=opt-in);其余通用
    if (!panelOpen()) {
      const p = profile.data;
      if (p.name) {
        showBubble((rootData().welcomeBack ?? '').replace('%s', p.name), 8000);
      } else if (returning && (p.askCount ?? 0) < 2) { // 回头无名,最多问 2 次(跨会话),之后不再打扰
        showBubble(rootData().askName ?? '', 9000);
        Z.awaitingName = true;
        Z.askNameAt = Date.now();
        p.askCount = (p.askCount ?? 0) + 1;
        profile.save();
      } else {
        showBubble(rootData().bubble ?? '', 8000);
      }
    }
  };
  // 深夜模式(23:00-6:00 进站):不演秀不冒气泡,已趴着睡;hover/开面板才醒(醒来天然接伸懒腰彩蛋)
  const nightInit = () => {
    sessionStorage.setItem('sigaoli-zoe-shown', '1');
    place();
    Z.state = 'sleep';
    void playZ('loaf', ++Z.gen);
  };
  const sitAtCorner = () => {
    place();
    if (Z.reduced) { Z.still!.hidden = false; showEl(Z.still!); Z.state = 'idle'; }
    else enterIdle();
  };

  // ---- 聊天联动(互动层):打字=倾听 / 等首 token=歪头思考 / 流式=轻拍打字(播完当前段切回) ----
  const zoeTyping = () => {
    markActivity(); scheduleSleep();
    if (!Z.interactive) return;
    if (Z.state === 'sleep') { void wake(); return; }
    if (Z.state === 'idle') { const g = ++Z.gen; Z.state = 'listen'; void playZ('listen', g); }
    clearTimeout(Z.listenTimer);
    Z.listenTimer = setTimeout(() => { if (Z.state === 'listen') enterIdle(); }, 4000);
  };
  const zoeChatStart = (text: string) => {
    markActivity(); scheduleSleep();
    if (!Z.interactive) return;
    if (!eggUsed('bow') && (THANKS_RE.test(text) || BYE_RE.test(text))) Z.pendingEgg = 'bow';
    clearTimeout(Z.listenTimer);
    const start = () => { const g = ++Z.gen; Z.state = 'think'; void playZ('think', g); };
    if (Z.state === 'sleep') void wake(start);
    // 演出中(彩蛋/进场/起身)不打断——锚点结构下中途硬切=姿势跳变;本轮不演思考,演完自然回 idle
    else if (Z.state === 'idle' || Z.state === 'listen' || Z.state === 'think' || Z.state === 'type') start();
  };
  const zoeChatStreaming = () => {
    if (!Z.interactive || Z.state !== 'think') return;
    const g = ++Z.gen;
    Z.state = 'type';
    // 打字阶段随机轮换:敲地面(type) / 傲娇昂首(proud),循环播——傲娇只在此处激活(07-15 Sigao 定)
    // 积压(PRD §23.5,Sigao 07-15):将来引入语义路由——简单问题→傲娇,复杂问题→敲地板
    void playZ(Math.random() < 0.5 ? 'type' : 'proud', g, true);
  };
  const zoeChatDone = () => {
    if (!Z.interactive) return;
    const egg = Z.pendingEgg; Z.pendingEgg = '';
    const finish = () => { if (egg) { useEgg(egg); void act(egg); } else enterIdle(); };
    if (Z.state === 'type') {
      // 「播完当前段切回」(§23.2):关 loop 等本轮播完,不生硬打断
      const v = Z.vids[Z.cur], g = Z.gen;
      v.loop = false;
      v.addEventListener('ended', () => { if (g === Z.gen) finish(); }, { once: true });
    } else if (Z.state === 'think' || Z.state === 'listen') finish();
  };

  // ================= 面板逻辑(每页 DOM 重建,运行时查询防引用过期) =================
  const bubbleMsg = (cls: 'user' | 'bot', html: string): HTMLElement => {
    const log = $('chat-log')!;
    const el = document.createElement('div');
    el.className = `chat-msg ${cls}`;
    el.innerHTML = html;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
    return el;
  };
  const paint = () => {
    const log = $('chat-log'), suggest = $('chat-suggest');
    if (!log || !suggest) return;
    log.innerHTML = '';
    guideEl = null; // 引导 chip 随 log 重绘清空
    bubbleMsg('bot', render(rootData().greeting ?? ''));
    for (const m of history) bubbleMsg(m.role === 'user' ? 'user' : 'bot', render(m.content));
    suggest.hidden = history.length > 0;
  };
  const setBusy = (b: boolean) => {
    busy = b;
    const btn = $('chat-send') as HTMLButtonElement | null;
    if (btn) btn.disabled = b;
  };
  // 面板开合状态跨页保持(View Transitions 切页后恢复;恢复时不抢焦点)
  const toggle = (open?: boolean, focus = true) => {
    const panel = $('chat-panel');
    if (!panel) return;
    const show = open ?? panel.hidden;
    panel.hidden = !show;
    Z.fab?.setAttribute('aria-expanded', String(show));
    sessionStorage.setItem('sigaoli-chat-open', show ? '1' : '0');
    if (show) {
      if (Z.bubbleEl) Z.bubbleEl.hidden = true;
      paint();
      if (focus) { ($('chat-input') as HTMLTextAreaElement | null)?.focus(); track('chat-open'); }
      warm(['listen', 'think', 'type']); // 聊天四件套预热
      markActivity(); scheduleSleep();
      if (Z.state === 'sleep') void wake();
    }
  };

  // 意图引导(§23.5):并行请求 /classify,拿到 chip 就在该条回复下方渲染可点引导(版块导航/邮箱)。
  // 失败/none/超限一律无引导——独立 fetch,与 /chat 解耦,绝不阻塞或影响主回复。
  const renderGuidanceChip = (chip: string, afterEl: HTMLElement) => {
    let guides: Record<string, { label: string; href: string }>;
    try { guides = JSON.parse(rootData().guides ?? '{}'); } catch { return; }
    const g = guides[chip];
    if (!g) return;
    if (guideEl) guideEl.remove(); // 只保留最新一条引导 chip
    const wrap = document.createElement('div');
    wrap.className = 'chat-guide';
    const a = document.createElement('a');
    a.href = g.href;
    a.className = 'chat-guide-chip';
    a.textContent = g.label;
    wrap.appendChild(a);
    afterEl.insertAdjacentElement('afterend', wrap);
    guideEl = wrap;
    const log = $('chat-log');
    if (log) log.scrollTop = log.scrollHeight;
  };
  const classifyGuidance = async (text: string, afterEl: HTMLElement) => {
    try {
      const { lang, api } = rootData();
      const res = await fetch(`${api}/classify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lang, message: text }),
      });
      if (!res.ok) return;
      const data = (await res.json()) as { chip?: string };
      if (data.chip && data.chip !== 'none') renderGuidanceChip(data.chip, afterEl);
    } catch { /* 引导锦上添花,失败静默 */ }
  };
  // 回头客问名(§23.5):已问名时,把访客下一条消息送 /classify mode=name 提取名字;空 = 软拒。
  const captureName = async (text: string): Promise<string> => {
    try {
      const { lang, api } = rootData();
      const res = await fetch(`${api}/classify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lang, message: text, mode: 'name' }),
      });
      if (!res.ok) return '';
      const data = (await res.json()) as { name?: string };
      return (data.name ?? '').trim();
    } catch { return ''; }
  };

  const send = async (text: string) => {
    // 问名进行中且未过期:这条若是名字→记住+确认(不发 /chat);不是/已过期→静默作罢(不罚,
    // 问询次数已由 askCount 上限控制),照常回答这条消息。
    if (Z.awaitingName) {
      Z.awaitingName = false;
      if (Date.now() - Z.askNameAt <= T.nameWindow) {
        setBusy(true);
        const name = await captureName(text);
        setBusy(false);
        if (name) {
          profile.data.name = name;
          profile.save();
          bubbleMsg('user', render(text));
          bubbleMsg('bot', render((rootData().nameAck ?? '').replace('%s', name)));
          return;
        }
      }
    }
    if (guideEl) { guideEl.remove(); guideEl = null; } // 新消息=清掉上一条回复的引导 chip
    track('chat-send');
    const { lang, api } = rootData();
    const errText: Record<string, string> = {
      rate_limited: rootData().errRate!,
      turn_limit: rootData().errTurns!,
      upstream_unavailable: rootData().errUpstream!,
      network: rootData().errNetwork!,
    };
    const suggest = $('chat-suggest');
    if (suggest) suggest.hidden = true;
    history.push({ role: 'user', content: text });
    store.save(history);
    bubbleMsg('user', render(text));
    const botEl = bubbleMsg('bot', '');
    botEl.classList.add('pending');
    setBusy(true);
    zoeChatStart(text);
    void classifyGuidance(text, botEl); // 并行意图分类,非阻塞
    aborter = new AbortController();
    let acc = '';
    try {
      const res = await fetch(`${api}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lang, messages: history }),
        signal: aborter.signal,
      });
      if (!res.ok || !res.body) {
        const code = (await res.json().catch(() => ({ error: '' }))).error as string;
        botEl.innerHTML = render(errText[code] ?? errText.upstream_unavailable);
        return;
      }
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      for (;;) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        let idx: number;
        while ((idx = buf.indexOf('\n')) >= 0) {
          const line = buf.slice(0, idx).trim();
          buf = buf.slice(idx + 1);
          if (!line.startsWith('data:')) continue;
          try {
            const evt = JSON.parse(line.slice(5));
            if (evt.delta) {
              acc += evt.delta;
              zoeChatStreaming();
              botEl.classList.remove('pending');
              botEl.innerHTML = render(acc);
              const log = $('chat-log');
              if (log) log.scrollTop = log.scrollHeight;
            }
          } catch { /* 忽略坏行 */ }
        }
      }
      if (acc) { history.push({ role: 'assistant', content: acc }); store.save(history); }
      else botEl.innerHTML = render(errText.upstream_unavailable);
    } catch {
      if (acc) { history.push({ role: 'assistant', content: acc }); store.save(history); }
      else botEl.innerHTML = render(errText.network);
    } finally {
      botEl.classList.remove('pending');
      setBusy(false);
      aborter = null;
      zoeChatDone();
    }
  };

  const trySend = (text: string) => {
    if (!text || busy) return;
    const input = $('chat-input') as HTMLTextAreaElement | null;
    if (history.filter((m) => m.role === 'user').length >= MAX_TURNS) {
      bubbleMsg('bot', render(rootData().errTurns ?? ''));
      return;
    }
    if (input) { input.value = ''; input.style.height = ''; }
    void send(text);
  };

  // ================= 全局单次绑定(仅首个页面执行) =================
  const bindGlobal = () => {
    // 舞台在 transition:persist 下跨页存活,监听只绑一次
    Z.fab!.addEventListener('click', () => { markActivity(); toggle(); });
    Z.fab!.addEventListener('pointerenter', onStageEnter);
    addEventListener('resize', place);
    addEventListener('click', markActivity, { capture: true, passive: true }); // 点导航/任意点击=活动

    // 滚动=活动(重置入睡计时)但不吵醒;页脚彩蛋随「凑近看你」移入切页反应池而取消(07-15)
    addEventListener('scroll', () => {
      Z.lastScroll = Date.now();
      markActivity();
    }, { passive: true });
  };

  pageScript(() => {
    const root = $('chat-root');
    if (!root) return;
    // 每页刷新 DOM 引用(舞台=persist 同节点;面板=新节点)
    Z.fab = $('chat-fab');
    Z.vids = [$('zoe-a') as HTMLVideoElement, $('zoe-b') as HTMLVideoElement];
    Z.still = $('zoe-still') as HTMLImageElement;
    Z.bubbleEl = $('zoe-bubble');
    // persist 舞台的本地化标签跟随当前页语言
    Z.fab?.setAttribute('aria-label', rootData().open ?? '');
    Z.fab?.setAttribute('title', rootData().open ?? '');

    if (!Z.booted) {
      Z.booted = true;
      history = store.load();
      profile.load();
      profile.data.visits += 1;
      profile.data.lastVisit = new Date().toISOString().slice(0, 10);
      profile.save();
      Z.reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      Z.interactive = !Z.reduced && innerWidth >= 768 && matchMedia('(pointer: fine)').matches;
      bindGlobal();
      const hour = new Date().getHours();
      const shown = !!sessionStorage.getItem('sigaoli-zoe-shown');
      const chatOpen = sessionStorage.getItem('sigaoli-chat-open') === '1';
      // 回头客=上个会话来过(localStorage 跨会话,sessionStorage 界定本会话)
      const returning = localStorage.getItem('sigaoli-zoe-seen') === '1' && !shown && !chatOpen;
      try { localStorage.setItem('sigaoli-zoe-seen', '1'); } catch { /* 隐私模式可拒 */ }
      if (!Z.interactive) sitAtCorner();
      else if (!shown && !chatOpen && (hour >= 23 || hour < 6)) nightInit();
      else if (!shown && !chatOpen) void entryShow(returning);
      else enterIdle();
      scheduleMicro();
    } else {
      pageSwitchReaction(); // persist 跨页不断帧,切页瞬间抽反应(§23.3)
    }

    // ---- 面板接线(每页新 DOM) ----
    const form = $('chat-form') as HTMLFormElement;
    const input = $('chat-input') as HTMLTextAreaElement;
    const onSubmit = (e: Event) => { e.preventDefault(); trySend(input.value.trim()); };
    const onChip = (e: Event) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('.chat-chip');
      if (chip) trySend(chip.textContent!.trim());
    };
    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
      if (e.key === 'Escape') toggle(false);
    };
    const onInput = () => {
      input.style.height = '';
      input.style.height = `${Math.min(input.scrollHeight, 112)}px`;
      zoeTyping();
    };
    const onReset = () => { history = []; store.clear(); paint(); input.focus(); };
    form.addEventListener('submit', onSubmit);
    $('chat-suggest')!.addEventListener('click', onChip);
    input.addEventListener('keydown', onKeydown);
    input.addEventListener('input', onInput);
    $('chat-reset')!.addEventListener('click', onReset);
    $('zoe-forget')?.addEventListener('click', forgetVisitor);
    if (sessionStorage.getItem('sigaoli-chat-open') === '1') toggle(true, false);

    // 清理只针对本页面板;Zoe 状态跨页存活(persist),不在此重置
    return () => {
      aborter?.abort();
      clearTimeout(Z.listenTimer);
      if (Z.state === 'listen' || Z.state === 'think') enterIdle(); // type 由 zoeChatDone 的 ended 收尾
    };
  });
</script>
