---
// Interactive flow field (套B · 河流) — CV page background. Data points stream
// along a slowly evolving vector field like a river; the cursor stirs a vortex.
// Ported from the validated effects-preview prototype — vanilla canvas, no deps.
---
<canvas id="flow-field" class="pointer-events-none absolute inset-0 -z-10 h-full w-full" aria-hidden="true"></canvas>

<script>
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  pageScript(() => {
    const canvas = document.getElementById('flow-field') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const rgb = (name: string, fallback: [number, number, number]): [number, number, number] => {
      const raw = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      ctx.fillStyle = raw;
      const s = ctx.fillStyle;
      if (s[0] === '#') {
        const n = parseInt(s.length === 4 ? s.slice(1).split('').map((c) => c + c).join('') : s.slice(1), 16);
        return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
      }
      const m = s.match(/\d+(\.\d+)?/g);
      return m ? [+m[0], +m[1], +m[2]] : fallback;
    };

    const perm = (() => {
      const p = Array.from({ length: 256 }, (_, i) => i);
      let s = 977;
      const rnd = () => { s = (s * 1103515245 + 12345) & 0x7fffffff; return s / 0x7fffffff; };
      for (let i = 255; i > 0; i--) { const j = Math.floor(rnd() * (i + 1)); [p[i], p[j]] = [p[j], p[i]]; }
      return p;
    })();
    const pat = (i: number) => perm[((i % 256) + 256) % 256];
    const fade = (t: number) => t * t * (3 - 2 * t);
    const lp = (a: number, b: number, t: number) => a + (b - a) * t;
    const vn = (x: number, y: number) => {
      const x0 = Math.floor(x), y0 = Math.floor(y), fx = fade(x - x0), fy = fade(y - y0);
      const v = (ix: number, iy: number) => pat(ix + pat(iy)) / 255;
      return lp(lp(v(x0, y0), v(x0 + 1, y0), fx), lp(v(x0, y0 + 1), v(x0 + 1, y0 + 1), fx), fy);
    };

    let w = 0, h = 0, parts: { x: number; y: number }[] = [];
    const dpr = Math.min(devicePixelRatio || 1, 1.75);
    const fit = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const N = Math.min(520, Math.round((w * h) / 7000));
      parts = Array.from({ length: N }, () => ({ x: Math.random() * w, y: Math.random() * h }));
      // canvas stays transparent — the page background shows through; trails fade
      // to transparent (see draw), so no muddy colour build-up.
    };
    fit();

    const mouse = { x: -9999, y: -9999, on: false };

    // Cache the resolved colours; re-read only when the theme class flips, not
    // every frame (getComputedStyle each frame forces a style recalc).
    let accRGB = rgb('--accent', [27, 73, 101]);

    const isTouch = matchMedia('(hover: none)').matches || innerWidth <= 768;
    if (prefersReducedMotion() || isTouch) {
      const acc = accRGB;
      ctx.globalAlpha = 0.35; ctx.fillStyle = `rgb(${acc[0]},${acc[1]},${acc[2]})`;
      for (const p of parts) ctx.fillRect(p.x, p.y, 1.4, 1.4);
      ctx.globalAlpha = 1;
      const onR = () => { fit(); };
      addEventListener('resize', onR, { passive: true });
      return () => removeEventListener('resize', onR);
    }

    let z = 0, raf = 0, running = true;
    const themeObs = new MutationObserver(() => { accRGB = rgb('--accent', [27, 73, 101]); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    const draw = () => {
      const acc = accRGB;
      // Fade existing trails toward TRANSPARENT (not toward the bg colour, which
      // muddied blue→cream into a yellowish tint). The page shows through cleanly.
      ctx.globalCompositeOperation = 'destination-out';
      ctx.fillStyle = 'rgba(0,0,0,0.085)';
      ctx.fillRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'source-over';
      for (const p of parts) {
        const a = vn(p.x * 0.006, p.y * 0.006 + z) * Math.PI * 4;
        let vx = Math.cos(a) * 0.9, vy = Math.sin(a) * 0.9, near = 0;
        if (mouse.on) {
          const dx = p.x - mouse.x, dy = p.y - mouse.y, d = Math.hypot(dx, dy) || 1;
          if (d < 130) {
            near = 1 - d / 130;
            vx += (-dy / d) * near * 2.4 + (-dx / d) * near * 0.5;
            vy += (dx / d) * near * 2.4 + (-dy / d) * near * 0.5;
          }
        }
        p.x += vx; p.y += vy;
        if (p.x < 0 || p.x > w || p.y < 0 || p.y > h) { p.x = Math.random() * w; p.y = Math.random() * h; }
        ctx.globalAlpha = 0.3 + near * 0.5;
        ctx.fillStyle = `rgb(${acc[0]},${acc[1]},${acc[2]})`;
        const s = 1.3 + near * 1.6;
        ctx.fillRect(p.x, p.y, s, s);
      }
      ctx.globalAlpha = 1;
      z += 0.0009;
      if (running) raf = requestAnimationFrame(draw);
    };
    raf = requestAnimationFrame(draw);

    const onMove = (e: MouseEvent) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top; mouse.on = true;
    };
    const onOut = () => { mouse.on = false; };
    const onVis = () => {
      running = document.visibilityState === 'visible';
      if (running) raf = requestAnimationFrame(draw); else cancelAnimationFrame(raf);
    };
    const onResize = () => fit();
    const ro = new ResizeObserver(() => fit());
    if (canvas.parentElement) ro.observe(canvas.parentElement);
    addEventListener('mousemove', onMove, { passive: true });
    document.addEventListener('mouseleave', onOut);
    document.addEventListener('visibilitychange', onVis);
    addEventListener('resize', onResize, { passive: true });

    return () => {
      cancelAnimationFrame(raf); running = false; ro.disconnect(); themeObs.disconnect();
      removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseleave', onOut);
      document.removeEventListener('visibilitychange', onVis);
      removeEventListener('resize', onResize);
    };
  });
</script>
