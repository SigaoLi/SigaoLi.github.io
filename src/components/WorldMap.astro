---
// Dotted world map (A9) — land sampled from Natural Earth (public domain),
// equirectangular projection: x=(lng+180)*2, y=(85-lat)*2, viewBox 720×300.
import dots from '../data/map-dots.json';

interface Country {
  id: string;
  name: string;
  /** Anchor position (centroid of geotagged photos, or country centroid) */
  lat: number;
  lng: number;
  count: number;
  /** Individual geotagged photos — position + city label (localized) */
  dots: { lat: number; lng: number; city?: string }[];
}
interface Props {
  countries: Country[];
}
const { countries } = Astro.props;

const px = (lng: number) => (lng + 180) * 2;
const py = (lat: number) => (85 - lat) * 2;
---

<div id="world-map" class="relative mx-auto max-w-5xl">
  <svg viewBox="0 0 720 300" class="w-full" role="img" aria-label="World map showing photographed countries">
    <g class="text-ink-muted" opacity="0.35">
      {(dots as [number, number][]).map(([x, y]) => <circle cx={x} cy={y} r="1.1" fill="currentColor" />)}
    </g>
    {countries.map((c) => (
      <a
        href={`#gallery-${c.id}`}
        class="map-marker group outline-none"
        data-country={c.id}
        aria-label={c.name}
      >
        {/* One dot per geotagged photo — the country's footprint, and the only
            hit target so neighbouring countries' dots aren't mis-attributed.
            Each dot shows its own city on hover. */}
        {c.dots.map((dot) => {
          const place = dot.city ? `${dot.city} · ${c.name}` : c.name;
          return (
            <circle
              cx={px(dot.lng)} cy={py(dot.lat)} r="2.4"
              fill="var(--accent)" opacity="0.75"
              data-place={place}
              class="map-dot transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100"
            >
              <title>{place}</title>
            </circle>
          );
        })}
      </a>
    ))}
  </svg>
  <div id="map-tooltip" class="pointer-events-none absolute hidden rounded-md border px-3 py-1.5 font-mono text-xs"
    style="border-color: var(--line); background: var(--bg-elevated); color: var(--ink);"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  gsap.registerPlugin(ScrollToPlugin);

  pageScript(() => {
    const map = document.getElementById('world-map');
    if (!map) return;
    const tooltip = document.getElementById('map-tooltip');

    const handlers: Array<[Element, string, EventListener]> = [];
    const on = (el: Element, ev: string, fn: EventListener) => {
      el.addEventListener(ev, fn);
      handlers.push([el, ev, fn]);
    };

    // Navigation: clicking a country's dots smooth-scrolls to its gallery.
    map.querySelectorAll<SVGAElement>('.map-marker').forEach((marker) => {
      const id = marker.dataset.country!;
      on(marker, 'click', ((e: Event) => {
        if (prefersReducedMotion()) return; // native anchor jump
        e.preventDefault();
        const t = document.getElementById(`gallery-${id}`);
        if (!t) return;
        gsap.to(window, { scrollTo: { y: t, offsetY: 80 }, duration: 0.8, ease: 'power3.inOut' });
        gsap.fromTo(
          t.querySelectorAll('figure'),
          { y: 18, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.5, stagger: 0.05, delay: 0.55, ease: 'power2.out', clearProps: 'all' }
        );
        history.replaceState(null, '', `#gallery-${id}`);
      }) as EventListener);
    });

    // Tooltip: each dot shows its own city.
    if (tooltip) {
      map.querySelectorAll<SVGCircleElement>('.map-dot').forEach((dot) => {
        on(dot, 'mousemove', ((e: Event) => {
          const me = e as MouseEvent;
          const r = map.getBoundingClientRect();
          tooltip.textContent = dot.dataset.place || '';
          tooltip.classList.remove('hidden');
          tooltip.style.left = `${me.clientX - r.left + 14}px`;
          tooltip.style.top = `${me.clientY - r.top - 10}px`;
        }) as EventListener);
        on(dot, 'mouseleave', (() => tooltip.classList.add('hidden')) as EventListener);
      });
    }

    return () => handlers.forEach(([el, ev, fn]) => el.removeEventListener(ev, fn));
  });
</script>
