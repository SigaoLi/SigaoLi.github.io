---
// Dotted world map (A9) — land sampled from Natural Earth (public domain),
// equirectangular projection: x=(lng+180)*2, y=(85-lat)*2, viewBox 720×300.
import dots from '../data/map-dots.json';

interface Country {
  id: string;
  name: string;
  /** Anchor position (centroid of geotagged photos, or country centroid) */
  lat: number;
  lng: number;
  count: number;
  /** Individual geotagged photos — position + city label (localized) */
  dots: { lat: number; lng: number; city?: string }[];
}
interface Props {
  countries: Country[];
}
const { countries } = Astro.props;

const px = (lng: number) => (lng + 180) * 2;
const py = (lat: number) => (85 - lat) * 2;

// 概念3 · 地理点网络：连接所有照片点成网（每点连最近 2 个），再叠加各国锚点
// 之间的洲际弧线作"航线"。弧线向上弓起，JS 让光点沿最长的几条行进。
type Pt = { x: number; y: number };
const arc = (a: Pt, b: Pt) => {
  const len = Math.hypot(a.x - b.x, a.y - b.y);
  const mx = (a.x + b.x) / 2;
  const my = (a.y + b.y) / 2 - len * 0.18;
  return { d: `M ${a.x.toFixed(1)} ${a.y.toFixed(1)} Q ${mx.toFixed(1)} ${my.toFixed(1)} ${b.x.toFixed(1)} ${b.y.toFixed(1)}`, len };
};
const nearestEdges = (pts: Pt[], k: number, minD: number) => {
  const seen = new Set<string>();
  const out: { d: string; len: number }[] = [];
  pts.forEach((a, i) => {
    pts
      .map((b, j) => ({ j, dd: Math.hypot(a.x - b.x, a.y - b.y) }))
      .filter((o) => o.j !== i && o.dd > minD)
      .sort((p, q) => p.dd - q.dd)
      .slice(0, k)
      .forEach((o) => {
        const key = i < o.j ? `${i}-${o.j}` : `${o.j}-${i}`;
        if (seen.has(key)) return;
        seen.add(key);
        out.push(arc(a, pts[o.j]));
      });
  });
  return out;
};
const allDots: Pt[] = countries.flatMap((c) => c.dots.map((dt) => ({ x: px(dt.lng), y: py(dt.lat) })));
// Each country's network anchor = its densest photo point (most neighbours
// within a small radius; ties broken toward the most central), so routes start
// from where the photos actually cluster — not the centroid, which can land in
// empty ocean between an east- and west-coast cluster.
const densest = (pts: Pt[]): Pt => {
  if (pts.length <= 1) return pts[0];
  const R = 8;
  let best = pts[0], bestScore = -Infinity;
  for (const a of pts) {
    let count = 0, sum = 0;
    for (const b of pts) {
      const dd = Math.hypot(a.x - b.x, a.y - b.y);
      if (dd <= R) count++;
      sum += dd;
    }
    const score = count - sum / 1e6;
    if (score > bestScore) { bestScore = score; best = a; }
  }
  return best;
};
const anchorPts: Pt[] = countries.map((c) => densest(c.dots.map((dt) => ({ x: px(dt.lng), y: py(dt.lat) }))));
const edges = [...nearestEdges(allDots, 2, 0.5), ...nearestEdges(anchorPts, 2, 0.5)];
const arcs = edges.map((e) => e.d);
// travelling light only on the longest arcs (the intercontinental "routes")
const pulseArcs = [...edges].sort((a, b) => b.len - a.len).slice(0, 12).map((e) => e.d);
---

<div id="world-map" class="relative mx-auto max-w-5xl">
  <svg viewBox="0 0 720 300" class="w-full" role="img" aria-label="World map showing photographed countries">
    <g class="text-ink-muted" opacity="0.35">
      {(dots as [number, number][]).map(([x, y]) => <circle cx={x} cy={y} r="1.1" fill="currentColor" />)}
    </g>
    <g class="map-net text-accent" aria-hidden="true">
      {arcs.map((d) => <path d={d} fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.14" />)}
      {pulseArcs.map((d) => <path d={d} fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" class="map-pulse" opacity="0.85" />)}
    </g>
    {countries.map((c) => (
      <a
        href={`#gallery-${c.id}`}
        class="map-marker group outline-none"
        data-country={c.id}
        aria-label={c.name}
      >
        {/* One dot per geotagged photo — the country's footprint, and the only
            hit target so neighbouring countries' dots aren't mis-attributed.
            Each dot shows its own city on hover. */}
        {c.dots.map((dot) => {
          const place = dot.city ? `${dot.city} · ${c.name}` : c.name;
          return (
            <circle
              cx={px(dot.lng)} cy={py(dot.lat)} r="2.4"
              fill="var(--accent)" opacity="0.75"
              data-place={place}
              class="map-dot transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100"
            >
              <title>{place}</title>
            </circle>
          );
        })}
      </a>
    ))}
  </svg>
  <div id="map-tooltip" class="pointer-events-none absolute hidden rounded-md border px-3 py-1.5 font-mono text-xs"
    style="border-color: var(--line); background: var(--bg-elevated); color: var(--ink);"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  gsap.registerPlugin(ScrollToPlugin);

  pageScript(() => {
    const map = document.getElementById('world-map');
    if (!map) return;
    const tooltip = document.getElementById('map-tooltip');

    const handlers: Array<[Element, string, EventListener]> = [];
    const on = (el: Element, ev: string, fn: EventListener) => {
      el.addEventListener(ev, fn);
      handlers.push([el, ev, fn]);
    };

    // 概念3：让一个短"光点"沿每条弧线行进（stroke-dashoffset，GPU 揭示）。
    const tweens: gsap.core.Tween[] = [];
    if (!prefersReducedMotion()) {
      map.querySelectorAll<SVGPathElement>('.map-pulse').forEach((path, i) => {
        const len = path.getTotalLength();
        path.style.strokeDasharray = `3 ${len}`;
        path.style.strokeDashoffset = '0';
        tweens.push(
          gsap.to(path, { strokeDashoffset: -(len + 3), duration: 3.5 + (i % 4), repeat: -1, ease: 'none', delay: i * 0.6 })
        );
      });
    }

    // Navigation: clicking a country's dots smooth-scrolls to its gallery.
    map.querySelectorAll<SVGAElement>('.map-marker').forEach((marker) => {
      const id = marker.dataset.country!;
      on(marker, 'click', ((e: Event) => {
        if (prefersReducedMotion()) return; // native anchor jump
        e.preventDefault();
        const t = document.getElementById(`gallery-${id}`);
        if (!t) return;
        gsap.to(window, { scrollTo: { y: t, offsetY: 80 }, duration: 0.8, ease: 'power3.inOut' });
        gsap.fromTo(
          t.querySelectorAll('figure'),
          { y: 18, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.5, stagger: 0.05, delay: 0.55, ease: 'power2.out', clearProps: 'all' }
        );
        history.replaceState(null, '', `#gallery-${id}`);
      }) as EventListener);
    });

    // Tooltip: each dot shows its own city.
    if (tooltip) {
      map.querySelectorAll<SVGCircleElement>('.map-dot').forEach((dot) => {
        on(dot, 'mousemove', ((e: Event) => {
          const me = e as MouseEvent;
          const r = map.getBoundingClientRect();
          tooltip.textContent = dot.dataset.place || '';
          tooltip.classList.remove('hidden');
          tooltip.style.left = `${me.clientX - r.left + 14}px`;
          tooltip.style.top = `${me.clientY - r.top - 10}px`;
        }) as EventListener);
        on(dot, 'mouseleave', (() => tooltip.classList.add('hidden')) as EventListener);
      });
    }

    return () => {
      handlers.forEach(([el, ev, fn]) => el.removeEventListener(ev, fn));
      tweens.forEach((t) => t.kill());
    };
  });
</script>
