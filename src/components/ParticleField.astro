<!-- A3: sparse dot field — map points / data points / network nodes (PRD §8).
     Dots near the cursor brighten, grow and shift to the accent colour, so the
     interaction reads clearly (inspired by antigravity.google, kept on-brand). -->
<canvas id="particle-field" class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

<style>
  /* Light mode: blend the ink into the paper; dark mode keeps the glow. */
  html:not(.dark) #particle-field { mix-blend-mode: multiply; }
</style>

<script>
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  pageScript(() => {
    const canvas = document.getElementById('particle-field') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Resolve a CSS var (hex or rgb) to an [r,g,b] triple via the canvas.
    const toRgb = (cssVar: string): [number, number, number] => {
      const raw = getComputedStyle(document.documentElement).getPropertyValue(cssVar).trim();
      ctx.fillStyle = raw;
      const s = ctx.fillStyle;
      if (s[0] === '#') {
        const n = parseInt(s.length === 4
          ? s.slice(1).split('').map((c) => c + c).join('')
          : s.slice(1), 16);
        return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
      }
      const m = s.match(/\d+(\.\d+)?/g) || ['120', '120', '120'];
      return [+m[0], +m[1], +m[2]];
    };

    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();

    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const lowEnd = (navigator.hardwareConcurrency ?? 8) <= 4;
    const N = isMobile || lowEnd ? 55 : 110;

    // Each dot has a slowly drifting "home" anchor; the cursor displaces it from
    // home, and a spring pulls the displacement back to 0 so it disperses again
    // once the cursor leaves.
    type P = { hx: number; hy: number; hvx: number; hvy: number; dx: number; dy: number; dvx: number; dvy: number; x: number; y: number; r: number; inf: number };
    const pts: P[] = Array.from({ length: N }, () => {
      const hx = Math.random() * w, hy = Math.random() * h;
      return {
        hx, hy,
        hvx: (Math.random() - 0.5) * 0.16,
        hvy: (Math.random() - 0.5) * 0.16,
        dx: 0, dy: 0, dvx: 0, dvy: 0,
        x: hx, y: hy,
        r: Math.random() * 1.5 + 0.9,
        inf: 0,
      };
    });

    const mouse = { x: -9999, y: -9999 };
    const onMove = (e: MouseEvent) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
    };
    const onLeave = () => { mouse.x = -9999; mouse.y = -9999; };

    const RADIUS = 150;          // cursor influence radius
    const RADIUS2 = RADIUS * RADIUS;
    const LINK = 100;

    // Cache the resolved colours; re-read only when the theme class flips, not
    // every frame (getComputedStyle each frame forces a style recalc).
    let base = toRgb('--ink-muted');
    let acc = toRgb('--accent');
    // Light mode reads a touch flat; give dots/links a little more presence (the
    // multiply blend that sinks the ink into the paper is set in CSS below).
    let light = !document.documentElement.classList.contains('dark');
    const themeObs = new MutationObserver(() => { base = toRgb('--ink-muted'); acc = toRgb('--accent'); light = !document.documentElement.classList.contains('dark'); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      const lerp = (a: number, b: number, t: number) => Math.round(a + (b - a) * t);

      for (const p of pts) {
        const t = p.inf; // 0 (far) → 1 (at cursor)
        ctx.globalAlpha = (light ? 0.5 : 0.42) + t * 0.5;
        ctx.fillStyle = `rgb(${lerp(base[0], acc[0], t)},${lerp(base[1], acc[1], t)},${lerp(base[2], acc[2], t)})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * (1 + t * 2.2) * (light ? 1.12 : 1), 0, Math.PI * 2);
        ctx.fill();
      }

      // Sparse connections — the "network" reading; brighten near the cursor.
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
          const d2 = dx * dx + dy * dy;
          if (d2 < LINK * LINK) {
            const near = Math.max(pts[i].inf, pts[j].inf);
            const fall = 1 - Math.sqrt(d2) / LINK;
            ctx.globalAlpha = fall * ((light ? 0.18 : 0.1) + near * 0.5);
            ctx.strokeStyle = `rgb(${lerp(base[0], acc[0], near)},${lerp(base[1], acc[1], near)},${lerp(base[2], acc[2], near)})`;
            ctx.lineWidth = 0.6 + near * 0.6;
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.stroke();
          }
        }
      }
      ctx.globalAlpha = 1;
    };

    if (prefersReducedMotion()) {
      draw(); // static constellation
      window.addEventListener('resize', () => { resize(); draw(); }, { passive: true });
      return () => themeObs.disconnect();
    }

    let raf = 0;
    let running = true;
    let lastStep = 0;
    const FRAME = 1000 / 30; // cap to ~30fps — ambient field, halves per-second work
    const tick = (now: number) => {
      if (running) raf = requestAnimationFrame(tick);
      if (now - lastStep < FRAME) return;
      lastStep = now;
      for (const p of pts) {
        // organic ambient drift of the home anchor — keeps the field gently
        // alive even when the cursor is still (wraps at the edges).
        p.hvx = Math.max(-0.22, Math.min(0.22, p.hvx + (Math.random() - 0.5) * 0.01));
        p.hvy = Math.max(-0.22, Math.min(0.22, p.hvy + (Math.random() - 0.5) * 0.01));
        p.hx += p.hvx; p.hy += p.hvy;
        if (p.hx < -10) p.hx = w + 10; if (p.hx > w + 10) p.hx = -10;
        if (p.hy < -10) p.hy = h + 10; if (p.hy > h + 10) p.hy = -10;

        // cursor gathers nearby dots; influence also drives colour/size
        const mdx = mouse.x - p.x, mdy = mouse.y - p.y;
        const d2 = mdx * mdx + mdy * mdy;
        if (d2 < RADIUS2 && d2 > 1) {
          const d = Math.sqrt(d2);
          p.inf = 1 - d / RADIUS;
          const pull = p.inf * 0.5;
          p.dvx += (mdx / d) * pull;
          p.dvy += (mdy / d) * pull;
        } else {
          p.inf += (0 - p.inf) * 0.08;   // ease influence back to 0
        }

        // spring the displacement back to home → dots disperse once the cursor
        // moves away
        p.dvx = (p.dvx - p.dx * 0.022) * 0.85;
        p.dvy = (p.dvy - p.dy * 0.022) * 0.85;
        p.dx += p.dvx; p.dy += p.dvy;

        p.x = p.hx + p.dx; p.y = p.hy + p.dy;
      }
      draw();
    };
    raf = requestAnimationFrame(tick);

    const onVis = () => {
      running = document.visibilityState === 'visible';
      if (running) raf = requestAnimationFrame(tick);
      else cancelAnimationFrame(raf);
    };
    const onResize = () => resize();

    if (!isMobile) {
      canvas.parentElement?.addEventListener('mousemove', onMove, { passive: true });
      canvas.parentElement?.addEventListener('mouseleave', onLeave, { passive: true });
    }
    document.addEventListener('visibilitychange', onVis);
    window.addEventListener('resize', onResize, { passive: true });

    return () => {
      cancelAnimationFrame(raf);
      running = false;
      themeObs.disconnect();
      canvas.parentElement?.removeEventListener('mousemove', onMove);
      canvas.parentElement?.removeEventListener('mouseleave', onLeave);
      document.removeEventListener('visibilitychange', onVis);
      window.removeEventListener('resize', onResize);
    };
  });
</script>
