---
// Interactive topographic contour field (套A · 地形) — Work page background.
// Ambient isolines, strongest at the top (the "concept 1" art piece) and
// fading behind the list; the terrain rises under the cursor. Ported from the
// validated effects-preview prototype — vanilla canvas, no deps.
---
<canvas
  id="terrain-field"
  class="pointer-events-none absolute inset-0 -z-10 h-full w-full"
  style="-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.9), rgba(0,0,0,0.4) 35%, rgba(0,0,0,0.12)); mask-image: linear-gradient(to bottom, rgba(0,0,0,0.9), rgba(0,0,0,0.4) 35%, rgba(0,0,0,0.12));"
  aria-hidden="true"></canvas>

<script>
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  pageScript(() => {
    const canvas = document.getElementById('terrain-field') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Resolve --accent (hex or rgb) to an [r,g,b] triple — re-read each frame so
    // it tracks the theme toggle, like ParticleField.
    const accent = (): [number, number, number] => {
      const raw = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
      ctx.fillStyle = raw;
      const s = ctx.fillStyle;
      if (s[0] === '#') {
        const n = parseInt(s.length === 4 ? s.slice(1).split('').map((c) => c + c).join('') : s.slice(1), 16);
        return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
      }
      const m = s.match(/\d+(\.\d+)?/g) || ['27', '73', '101'];
      return [+m[0], +m[1], +m[2]];
    };

    // cheap value noise
    const perm = (() => {
      const p = Array.from({ length: 256 }, (_, i) => i);
      let s = 1337;
      const rnd = () => { s = (s * 1103515245 + 12345) & 0x7fffffff; return s / 0x7fffffff; };
      for (let i = 255; i > 0; i--) { const j = Math.floor(rnd() * (i + 1)); [p[i], p[j]] = [p[j], p[i]]; }
      return p;
    })();
    const pat = (i: number) => perm[((i % 256) + 256) % 256];
    const fade = (t: number) => t * t * (3 - 2 * t);
    const lp = (a: number, b: number, t: number) => a + (b - a) * t;
    const vn = (x: number, y: number) => {
      const x0 = Math.floor(x), y0 = Math.floor(y), fx = fade(x - x0), fy = fade(y - y0);
      const v = (ix: number, iy: number) => pat(ix + pat(iy)) / 255;
      return lp(lp(v(x0, y0), v(x0 + 1, y0), fx), lp(v(x0, y0 + 1), v(x0 + 1, y0 + 1), fx), fy);
    };

    let w = 0, h = 0;
    const dpr = Math.min(devicePixelRatio || 1, 1.75);
    const fit = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    fit();

    const cell = 18, scale = 0.07, levels = [0.32, 0.42, 0.52, 0.62, 0.72];
    const mouse = { x: -9999, y: -9999 };

    // Cache the accent colour and re-read it only when the theme class flips,
    // instead of calling getComputedStyle every frame (a forced style recalc).
    let acc = accent();
    let accentStr = `rgb(${acc[0]},${acc[1]},${acc[2]})`;
    const refreshAccent = () => { acc = accent(); accentStr = `rgb(${acc[0]},${acc[1]},${acc[2]})`; };
    const themeObs = new MutationObserver(refreshAccent);
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    let field: Float32Array | null = null;
    const ix = (a: number, b: number, lv: number) => (lv - a) / (b - a || 1e-6);

    const drawField = (t: number, bump: number) => {
      ctx.clearRect(0, 0, w, h);
      const ci = mouse.x / cell, cj = mouse.y / cell, sig2 = 2 * 3.4 * 3.4;
      const hasBump = bump > 0.01;
      const cols = Math.ceil(w / cell);
      // only march rows in (and just around) the viewport — keeps cost ~one
      // screenful regardless of how tall the page is.
      const top = canvas.getBoundingClientRect().top;
      const jStart = Math.max(0, Math.floor((-top - cell) / cell));
      const jEnd = Math.min(Math.ceil(h / cell), Math.ceil((-top + innerHeight + cell) / cell));
      // Sample the scalar field ONCE per grid point in the visible band, then run
      // marching squares for every level off the cached grid — previously the
      // same noise point was recomputed ~20× (4 corners × 5 levels).
      const gw = cols + 1, gRows = jEnd - jStart + 1;
      if (!field || field.length < gw * gRows) field = new Float32Array(gw * gRows);
      for (let jj = 0; jj < gRows; jj++) {
        const j = jStart + jj;
        for (let i = 0; i < gw; i++) {
          let v = vn(i * scale, j * scale + t);
          if (hasBump) { const di = i - ci, dj = j - cj; v += bump * 0.6 * Math.exp(-(di * di + dj * dj) / sig2); }
          field[jj * gw + i] = v;
        }
      }
      const at = (i: number, j: number) => field![(j - jStart) * gw + i];
      ctx.strokeStyle = accentStr;
      ctx.lineWidth = 1;
      let Tx = 0, Rx = 0, Ry = 0, Bx = 0, Ly = 0;
      for (let L = 0; L < levels.length; L++) {
        const lv = levels[L];
        ctx.globalAlpha = 0.5 * (0.45 + 0.55 * L / levels.length);
        ctx.beginPath();
        for (let j = jStart; j < jEnd; j++) for (let i = 0; i < cols; i++) {
          const a = at(i, j), b = at(i + 1, j), c = at(i + 1, j + 1), d = at(i, j + 1);
          let id = 0; if (a > lv) id |= 8; if (b > lv) id |= 4; if (c > lv) id |= 2; if (d > lv) id |= 1;
          if (id === 0 || id === 15) continue; // uniform cell — no contour line
          const x = i * cell, y = j * cell;
          Tx = x + cell * ix(a, b, lv); Rx = x + cell; Ry = y + cell * ix(b, c, lv);
          Bx = x + cell * ix(d, c, lv); Ly = y + cell * ix(a, d, lv);
          switch (id) {
            case 1: case 14: ctx.moveTo(x, Ly); ctx.lineTo(Bx, y + cell); break;
            case 2: case 13: ctx.moveTo(Bx, y + cell); ctx.lineTo(Rx, Ry); break;
            case 3: case 12: ctx.moveTo(x, Ly); ctx.lineTo(Rx, Ry); break;
            case 4: case 11: ctx.moveTo(Tx, y); ctx.lineTo(Rx, Ry); break;
            case 5: ctx.moveTo(x, Ly); ctx.lineTo(Tx, y); ctx.moveTo(Bx, y + cell); ctx.lineTo(Rx, Ry); break;
            case 6: case 9: ctx.moveTo(Tx, y); ctx.lineTo(Bx, y + cell); break;
            case 7: case 8: ctx.moveTo(x, Ly); ctx.lineTo(Tx, y); break;
            case 10: ctx.moveTo(Tx, y); ctx.lineTo(Rx, Ry); ctx.moveTo(x, Ly); ctx.lineTo(Bx, y + cell); break;
          }
        }
        ctx.stroke();
      }
      if (hasBump) {
        const g = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 50);
        g.addColorStop(0, `rgba(${acc[0]},${acc[1]},${acc[2]},${0.18 * bump})`);
        g.addColorStop(1, `rgba(${acc[0]},${acc[1]},${acc[2]},0)`);
        ctx.globalAlpha = 1; ctx.fillStyle = g; ctx.beginPath(); ctx.arc(mouse.x, mouse.y, 50, 0, 7); ctx.fill();
      }
      ctx.globalAlpha = 1;
      // (vertical "strong at top, faint over the list" fade is now a static CSS
      //  mask on the canvas — applied by the compositor, no per-frame cost.)
    };

    const isTouch = matchMedia('(hover: none)').matches || innerWidth <= 768;
    if (prefersReducedMotion() || isTouch) {
      drawField(0, 0);
      const onR = () => { fit(); drawField(0, 0); };
      addEventListener('resize', onR, { passive: true });
      return () => { removeEventListener('resize', onR); themeObs.disconnect(); };
    }

    let t = 0, bump = 0, raf = 0, running = true, over = false, lastDraw = 0;
    const FRAME = 1000 / 30; // cap redraws ~30fps — the field evolves slowly
    const onMove = (e: MouseEvent) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top; over = true;
    };
    const onOut = () => { over = false; };
    const ro = new ResizeObserver(() => fit());
    if (canvas.parentElement) ro.observe(canvas.parentElement);
    const tick = (now: number) => {
      if (now - lastDraw >= FRAME) {
        lastDraw = now;
        bump += ((over ? 1 : 0) - bump) * 0.11;
        drawField(t, bump);
        t += 0.0026;
      }
      if (running) raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);

    const onVis = () => {
      running = document.visibilityState === 'visible';
      if (running) raf = requestAnimationFrame(tick); else cancelAnimationFrame(raf);
    };
    const onResize = () => fit();
    addEventListener('mousemove', onMove, { passive: true });
    document.addEventListener('mouseleave', onOut);
    document.addEventListener('visibilitychange', onVis);
    addEventListener('resize', onResize, { passive: true });

    return () => {
      cancelAnimationFrame(raf); running = false;
      ro.disconnect();
      themeObs.disconnect();
      removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseleave', onOut);
      document.removeEventListener('visibilitychange', onVis);
      removeEventListener('resize', onResize);
    };
  });
</script>
