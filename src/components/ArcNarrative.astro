---

<!-- Desktop: pinned narrative -->
<section id="arc-desktop" class="hidden lg:block relative" aria-label="Career narrative">
  <div class="arc-pin mx-auto flex h-screen max-w-6xl items-center px-6">
    <div class="grid w-full grid-cols-2 gap-16 items-center">
      <div class="relative h-72">
        {acts.map((a) => (
          <div class="arc-text absolute inset-0 flex flex-col justify-center" data-act={a.id}>
            <p class="font-mono text-xs tracking-[0.2em]" style={`color:${a.color}`}>{a.label}</p>
            <p class="mt-2 font-mono text-xs text-ink-muted">{a.coords} · {a.place}</p>
            <h3 class="mt-4 font-display text-4xl">{a.title}</h3>
            <p class="mt-4 max-w-md text-ink-muted">{a.body}</p>
          </div>
        ))}
      </div>
      <div class="relative aspect-[480/400]">
        {acts.map((a) => (
          <div class="arc-visual absolute inset-0" data-act={a.id} set:html={svgs[a.id]} />
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Mobile & no-JS & reduced-motion: stacked acts -->
<section id="arc-mobile" class="lg:hidden mx-auto max-w-3xl px-6 py-20 flex flex-col gap-20" aria-label="Career narrative">
  {acts.map((a) => (
    <div>
      <p class="font-mono text-xs tracking-[0.2em]" style={`color:${a.color}`}>{a.label}</p>
      <p class="mt-2 font-mono text-xs text-ink-muted">{a.coords} · {a.place}</p>
      <h3 class="mt-3 font-display text-3xl">{a.title}</h3>
      <p class="mt-3 text-ink-muted">{a.body}</p>
      <div class="mt-6 max-w-sm" set:html={svgs[a.id]} />
    </div>
  ))}
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin';
  import { pageScript, prefersReducedMotion } from '../lib/motion';

  gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin);

  pageScript(() => {
    const root = document.getElementById('arc-desktop');
    if (!root || prefersReducedMotion()) return;
    if (!window.matchMedia('(min-width: 1024px)').matches) return;

    const ctx = gsap.context(() => {
      const acts = ['geo', 'biz', 'ai'];
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: root,
          start: 'top top',
          end: '+=2600',
          pin: '.arc-pin',
          scrub: 1,
        },
      });

      acts.forEach((id, i) => {
        const text = root.querySelector(`.arc-text[data-act="${id}"]`);
        const visual = root.querySelector(`.arc-visual[data-act="${id}"]`);
        const pos = i * 3;

        // enter
        tl.fromTo(text, { autoAlpha: 0, y: 36 }, { autoAlpha: 1, y: 0, duration: 0.7 }, pos);
        tl.fromTo(visual, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.5 }, pos);
        tl.fromTo(visual!.querySelectorAll('.draw'), { drawSVG: '0%' }, { drawSVG: '100%', duration: 1.6, stagger: 0.12, ease: 'none' }, pos + 0.2);
        tl.fromTo(visual!.querySelectorAll('.node'), { scale: 0, transformOrigin: 'center' }, { scale: 1, duration: 0.4, stagger: 0.08 }, pos + 0.9);

        // exit (all but last)
        if (i < acts.length - 1) {
          tl.to(text, { autoAlpha: 0, y: -36, duration: 0.6 }, pos + 2.4);
          tl.to(visual, { autoAlpha: 0, duration: 0.6 }, pos + 2.4);
        }
      });
    }, root);

    return () => ctx.revert();
  });
</script>

<style>
  /* Pre-JS state on desktop: hide all but let JS reveal; if JS fails, show last act */
  #arc-desktop .arc-text,
  #arc-desktop .arc-visual {
    visibility: hidden;
  }
  #arc-desktop .arc-text:last-of-type,
  #arc-desktop .arc-visual:last-of-type {
    visibility: visible;
  }
</style>
